<UserControl x:Class="AniNest.Features.Player.ControlBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:AniNest.Presentation.Behaviors"
             xmlns:animations="clr-namespace:AniNest.Presentation.Animations"
             xmlns:overlays="clr-namespace:AniNest.Presentation.Overlays"
             xmlns:primitives="clr-namespace:AniNest.Presentation.Primitives"
             Focusable="True">
    <Grid x:Name="RootGrid" Height="{StaticResource ControlBarHeight}"
          Focusable="True">
        <Grid.Background>
            <StaticResource ResourceKey="ControlBarBackground"/>
        </Grid.Background>

        <Grid Margin="{StaticResource ControlBarHorizontalMargin}"
              VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <Button x:Name="PreviousBtn" Style="{StaticResource AnimatedIconButton}"
                        Command="{Binding PreviousCommand}" ToolTip="{Binding PreviousTooltip}"
                        Focusable="False"
                        Margin="{StaticResource ButtonGapRight}">
                    <Image Source="/Resources/Icons/previous.png"
                           Style="{StaticResource PlayerControlBarIconImageSmall}"/>
                </Button>
                <Button x:Name="PlayPauseBtn" Style="{StaticResource AnimatedIconButton}"
                        Width="{StaticResource PlayPauseButtonSize}"
                        Height="{StaticResource PlayPauseButtonSize}"
                        Opacity="0.85" Command="{Binding PlayPauseCommand}"
                        Margin="{StaticResource ButtonGapBoth}"
                        ToolTip="{Binding PlayPauseTooltip}" Focusable="False">
                    <Grid animations:IconCrossfader.IsActive="{Binding IsPlaying}"
                          animations:IconCrossfader.ListenButton="{Binding ElementName=PlayPauseBtn}">
                        <Image Source="/Resources/Icons/play.png"
                               Style="{StaticResource PlayerControlBarIconImageLarge}"
                               Opacity="1"/>
                        <Image Source="/Resources/Icons/pause.png"
                               Style="{StaticResource PlayerControlBarIconImageLarge}"
                               Opacity="0"/>
                    </Grid>
                </Button>
                <Button x:Name="NextBtn" Style="{StaticResource AnimatedIconButton}"
                        Command="{Binding NextCommand}" ToolTip="{Binding NextTooltip}"
                        Focusable="False"
                        Margin="{StaticResource ButtonGapRight}">
                    <Image Source="/Resources/Icons/next.png"
                           Style="{StaticResource PlayerControlBarIconImageSmall}"/>
                </Button>
                <Button x:Name="StopBtn" Style="{StaticResource AnimatedIconButton}"
                        Command="{Binding StopCommand}"
                        Margin="{StaticResource ButtonGapLeft}" ToolTip="{Binding DataContext.Localization[Player.Stop], RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Focusable="False">
                    <Image Source="/Resources/Icons/stop.png"
                           Style="{StaticResource PlayerControlBarIconImageSmall}"/>
                </Button>
                <TextBlock Text="{Binding CurrentTimeText, FallbackValue='00:00'}"
                           Style="{StaticResource PlayerControlBarTimeText}"
                           Margin="{StaticResource TimeTextLeftMargin}"/>
                <TextBlock Text=" / "
                           Style="{StaticResource PlayerControlBarTimeSeparatorText}"/>
                <TextBlock Text="{Binding TotalTimeText, FallbackValue='00:00'}"
                           Style="{StaticResource PlayerControlBarTimeText}"/>
            </StackPanel>

            <primitives:SeekBar x:Name="SeekBar" Grid.Column="1"
                                Position="{Binding CurrentTime, Mode=OneWay}"
                                Duration="{Binding TotalTime}"
                                BufferedPosition="{Binding BufferedPosition}"
                                IsSeeking="{Binding IsSeeking, Mode=TwoWay}"
                                SeekCommand="{Binding SeekCommand}"
                                ThumbnailPreview="{Binding ThumbnailPreview}"
                                behaviors:HoverPopupBehavior.Controller="{Binding ThumbnailPreview.HoverPopupController}"
                                behaviors:HoverPopupBehavior.Zone="Host"
                                VerticalAlignment="Center"
                                ShowTooltip="False"
                                Margin="{StaticResource ControlBarSliderMargin}"/>

            <primitives:AnimatedPopup PlacementTarget="{Binding ElementName=SeekBar}"
                   PlacementPreset="Relative"
                   AllowsTransparency="True"
                   IsHitTestVisible="False"
                   StaysOpen="True"
                   IsOpenAnimated="{Binding ThumbnailPreview.IsOpen}"
                   OpenAnimationOrigin="0.5,1"
                   HorizontalOffset="{Binding ThumbnailPreview.HOffset}"
                   VerticalOffset="{Binding ThumbnailPreview.PopupVerticalOffset}">
                <Grid Width="{Binding ThumbnailPreview.PopupWidth}">
                    <Border x:Name="ThumbnailImageBorder"
                            Width="{StaticResource ThumbnailPopupWidth}"
                            Height="{StaticResource ThumbnailPopupHeight}"
                            behaviors:HoverPopupBehavior.Controller="{Binding ThumbnailPreview.HoverPopupController}"
                            behaviors:HoverPopupBehavior.Zone="Popup"
                            Visibility="{Binding ThumbnailPreview.ImageVisibility}">
                        <Border.Clip>
                            <RectangleGeometry RadiusX="{StaticResource ThumbnailPreviewImageClipRadius}"
                                               RadiusY="{StaticResource ThumbnailPreviewImageClipRadius}"
                                               Rect="0,0,160,90"/>
                        </Border.Clip>
                        <Image Source="{Binding ThumbnailPreview.ImageSource}"
                               Width="{StaticResource ThumbnailPopupWidth}"
                               Height="{StaticResource ThumbnailPopupHeight}"
                               Stretch="UniformToFill"/>
                    </Border>
                    <Border Style="{StaticResource PlayerThumbnailPreviewTimeBorder}"
                            behaviors:HoverPopupBehavior.Controller="{Binding ThumbnailPreview.HoverPopupController}"
                            behaviors:HoverPopupBehavior.Zone="Popup">
                        <TextBlock Text="{Binding ThumbnailPreview.TimeText}"
                                   Style="{StaticResource PlayerThumbnailPreviewTimeText}"/>
                    </Border>
                </Grid>
            </primitives:AnimatedPopup>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Grid>
                    <Button x:Name="SpeedBtn"
                            Style="{StaticResource PlayerSpeedButton}"
                            Margin="{StaticResource ButtonGapRight}"
                            Click="SpeedBtn_Click"
                            animations:ButtonScaleHover.IsEnabled="True">
                        <Grid animations:TextSwapAnimator.Text="{Binding Rate, StringFormat={}{0:0.0#}x}">
                            <TextBlock Text=""
                                       Style="{StaticResource PlayerSpeedAnimatedText}"
                                       Opacity="0">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text=""
                                       Style="{StaticResource PlayerSpeedAnimatedText}"
                                       Opacity="1">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Button>
                </Grid>

                <Button x:Name="PlaylistToggleBtn" Style="{StaticResource AnimatedIconButton}"
                        Command="{Binding TogglePlaylistCommand}"
                        Margin="{StaticResource ButtonGapLeft}" ToolTip="{Binding DataContext.Localization[Player.Playlist], RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Focusable="False">
                    <Image Source="/Resources/Icons/playlist.png"
                           Style="{StaticResource PlayerControlBarIconImageNormal}"/>
                </Button>
                <Button x:Name="FullscreenBtn"
                        Style="{StaticResource PlayerFullscreenButton}"
                        Margin="{StaticResource ButtonGapLeft}" Focusable="False"
                        Command="{Binding ToggleFullscreenCommand}"
                        animations:ButtonScaleHover.IsEnabled="True">
                    <Image Style="{StaticResource PlayerFullscreenButtonIcon}"/>
                </Button>
            </StackPanel>
        </Grid>

        <overlays:AnimatedOverlay x:Name="SpeedOverlay"
                                  Style="{StaticResource PlayerSpeedOverlay}"
                                  Panel.ZIndex="1000">
            <Border Style="{StaticResource PopupMenuOverlayBorder}"
                    MinWidth="{StaticResource SpeedPopupMinWidth}">
                <Grid>
                    <Border Style="{StaticResource PlayerSpeedOverlayHighlight}"
                            animations:SlideAnimator.TargetY="{Binding Rate, Converter={StaticResource RateToOffsetConverter}}">
                        <Border.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </Border.RenderTransform>
                    </Border>
                    <ItemsControl ItemsSource="{Binding SpeedOptions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource PlayerSpeedOptionButton}"
                                        Command="{Binding DataContext.ChangeSpeedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Click="SpeedOption_Click">
                                    <TextBlock Text="{Binding StringFormat={}{0:0.0#}x}"
                                               Style="{StaticResource PlayerSpeedOptionText}"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </overlays:AnimatedOverlay>
    </Grid>
</UserControl>



