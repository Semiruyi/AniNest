<UserControl x:Class="AniNest.Features.Player.ControlBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:AniNest.Presentation.Behaviors"
             xmlns:animations="clr-namespace:AniNest.Presentation.Animations"
             xmlns:converters="clr-namespace:AniNest.Presentation.Converters"
             xmlns:overlays="clr-namespace:AniNest.Presentation.Overlays"
             xmlns:primitives="clr-namespace:AniNest.Presentation.Primitives"
             Focusable="True">
    <UserControl.Resources>
        <converters:RateToOffsetConverter x:Key="RateToOffsetConverter"/>

        <Style x:Key="PlayerControlBarTimeText" TargetType="TextBlock" BasedOn="{StaticResource AppTextCaption}">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PlayerControlBarTimeSeparatorText" TargetType="TextBlock" BasedOn="{StaticResource PlayerControlBarTimeText}">
            <Setter Property="Foreground" Value="{StaticResource ControlBarTimeSeparatorForeground}"/>
            <Setter Property="Margin" Value="{StaticResource TimeSeparatorMargin}"/>
        </Style>

        <Style x:Key="PlayerControlBarIconImageSmall" TargetType="Image">
            <Setter Property="Width" Value="{StaticResource IconSizeSmall}"/>
            <Setter Property="Height" Value="{StaticResource IconSizeSmall}"/>
        </Style>

        <Style x:Key="PlayerControlBarIconImageNormal" TargetType="Image">
            <Setter Property="Width" Value="{StaticResource IconSizeNormal}"/>
            <Setter Property="Height" Value="{StaticResource IconSizeNormal}"/>
        </Style>

        <Style x:Key="PlayerControlBarIconImageLarge" TargetType="Image">
            <Setter Property="Width" Value="{StaticResource IconSizeLarge}"/>
            <Setter Property="Height" Value="{StaticResource IconSizeLarge}"/>
        </Style>

        <Style x:Key="PlayerControlBarVolumeSlider" TargetType="Slider">
            <Setter Property="Width" Value="{StaticResource VolumeSliderWidth}"/>
            <Setter Property="Height" Value="{StaticResource VolumeSliderHeight}"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="SmallChange" Value="1"/>
            <Setter Property="LargeChange" Value="10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="{TemplateBinding Height}">
                            <Border Height="{StaticResource VolumeTrackHeight}"
                                    VerticalAlignment="Center"
                                    Background="{StaticResource ProgressTrackBackground}"
                                    CornerRadius="{StaticResource ProgressBarThinCornerRadius}"/>
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="{StaticResource ProgressFillPrimary}"
                                                  BorderThickness="0"
                                                  Height="{StaticResource VolumeTrackHeight}"
                                                  VerticalAlignment="Center">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="{StaticResource ProgressBarThinCornerRadius}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="{StaticResource VolumeThumbSize}"
                                           Height="{StaticResource VolumeThumbSize}"
                                           Background="{StaticResource TextPrimary}"
                                           BorderThickness="0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="6"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="{StaticResource TransparentBrush}"
                                                  BorderThickness="0"
                                                  Height="{StaticResource VolumeTrackHeight}"
                                                  VerticalAlignment="Center">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="{TemplateBinding Background}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerControlBarSpeedOptionButton" TargetType="Button" BasedOn="{StaticResource PopupMenuButton}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PlayerControlBarSpeedAnimatedText" TargetType="TextBlock" BasedOn="{StaticResource AppTextBody}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>

        <Style x:Key="PlayerThumbnailPreviewTimeBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource ThumbnailPreviewTimeBackground}"/>
            <Setter Property="CornerRadius" Value="{StaticResource ThumbnailPreviewTimeCornerRadius}"/>
            <Setter Property="Padding" Value="{StaticResource ThumbnailPreviewTimePadding}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Bottom"/>
        </Style>

        <Style x:Key="PlayerThumbnailPreviewImageBorder" TargetType="Border">
            <Setter Property="Width" Value="{StaticResource ThumbnailPopupWidth}"/>
            <Setter Property="Height" Value="{StaticResource ThumbnailPopupHeight}"/>
            <Setter Property="Clip">
                <Setter.Value>
                    <RectangleGeometry RadiusX="{StaticResource ThumbnailPreviewImageClipRadius}"
                                       RadiusY="{StaticResource ThumbnailPreviewImageClipRadius}"
                                       Rect="0,0,160,90"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerThumbnailPreviewImage" TargetType="Image">
            <Setter Property="Width" Value="{StaticResource ThumbnailPopupWidth}"/>
            <Setter Property="Height" Value="{StaticResource ThumbnailPopupHeight}"/>
            <Setter Property="Stretch" Value="UniformToFill"/>
        </Style>

        <Style x:Key="PlayerThumbnailPreviewTimeText" TargetType="TextBlock" BasedOn="{StaticResource AppTextThumbnailPreview}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="PlayerSpeedOverlay"
               TargetType="{x:Type overlays:AnimatedOverlay}"
               BasedOn="{StaticResource {x:Type overlays:AnimatedOverlay}}">
            <Setter Property="InteractionPreset" Value="ToolPanelLike"/>
            <Setter Property="Placement" Value="TopCenter"/>
            <Setter Property="ConstrainToHostBounds" Value="False"/>
            <Setter Property="VerticalOffset" Value="{StaticResource OverlayVerticalOffsetProminent}"/>
            <Setter Property="AnimationOrigin" Value="0.5,1"/>
        </Style>

        <Style x:Key="PlayerSpeedOverlayHighlight" TargetType="Border">
            <Setter Property="CornerRadius" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <Style x:Key="PlayerSpeedOptionText" TargetType="TextBlock" BasedOn="{StaticResource AppTextBody}">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PlayerControlBarPreviousButton" TargetType="Button" BasedOn="{StaticResource PlayerPreviousButton}">
            <Setter Property="Command" Value="{Binding PreviousCommand}"/>
            <Setter Property="ToolTip" Value="{Binding PreviousTooltip}"/>
            <Setter Property="Content" Value=""/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Image Source="/Resources/Icons/previous.png"
                               Style="{StaticResource PlayerControlBarIconImageSmall}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerControlBarPlayPauseButton" TargetType="Button" BasedOn="{StaticResource PlayerPlayPauseButton}">
            <Setter Property="Command" Value="{Binding PlayPauseCommand}"/>
            <Setter Property="ToolTip" Value="{Binding PlayPauseTooltip}"/>
            <Setter Property="Content" Value=""/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid animations:IconCrossfader.IsActive="{Binding DataContext.IsPlaying, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              animations:IconCrossfader.ListenButton="{Binding RelativeSource={RelativeSource AncestorType=Button}}">
                            <Image Source="/Resources/Icons/play.png"
                                   Style="{StaticResource PlayerControlBarIconImageLarge}"
                                   Opacity="1"/>
                            <Image Source="/Resources/Icons/pause.png"
                                   Style="{StaticResource PlayerControlBarIconImageLarge}"
                                   Opacity="0"/>
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerControlBarNextButton" TargetType="Button" BasedOn="{StaticResource PlayerNextButton}">
            <Setter Property="Command" Value="{Binding NextCommand}"/>
            <Setter Property="ToolTip" Value="{Binding NextTooltip}"/>
            <Setter Property="Content" Value=""/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Image Source="/Resources/Icons/next.png"
                               Style="{StaticResource PlayerControlBarIconImageSmall}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerControlBarStopButton" TargetType="Button" BasedOn="{StaticResource PlayerStopButton}">
            <Setter Property="Command" Value="{Binding StopCommand}"/>
            <Setter Property="ToolTip"
                    Value="{Binding DataContext.Localization[Player.Stop], RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Content" Value=""/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Image Source="/Resources/Icons/stop.png"
                               Style="{StaticResource PlayerControlBarIconImageSmall}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerControlBarSpeedButton" TargetType="Button" BasedOn="{StaticResource PlayerSpeedButton}">
            <Setter Property="Margin" Value="{StaticResource ButtonGapRight}"/>
            <Setter Property="Content" Value=""/>
            <EventSetter Event="Click" Handler="SpeedBtn_Click"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Grid animations:TextSwapAnimator.Text="{Binding DataContext.Rate, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat={}{0:0.0#}x}">
                            <TextBlock Text=""
                                       Style="{StaticResource PlayerControlBarSpeedAnimatedText}"
                                       Opacity="0">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text=""
                                       Style="{StaticResource PlayerControlBarSpeedAnimatedText}"
                                       Opacity="1">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerControlBarPlaylistButton" TargetType="Button" BasedOn="{StaticResource PlayerPlaylistButton}">
            <Setter Property="Command" Value="{Binding TogglePlaylistCommand}"/>
            <Setter Property="ToolTip"
                    Value="{Binding DataContext.Localization[Player.Playlist], RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Content" Value=""/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Image Source="/Resources/Icons/playlist.png"
                               Style="{StaticResource PlayerControlBarIconImageNormal}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerControlBarVolumeButton" TargetType="Button" BasedOn="{StaticResource AnimatedIconButton}">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Margin" Value="{StaticResource VolumeButtonMargin}"/>
            <Setter Property="Command" Value="{Binding ToggleMuteCommand}"/>
            <Setter Property="ToolTip" Value="{Binding VolumeTooltip}"/>
            <Setter Property="Content" Value=""/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Image>
                            <Image.Style>
                                <Style TargetType="Image" BasedOn="{StaticResource PlayerControlBarIconImageNormal}">
                                    <Setter Property="Source" Value="/Resources/Icons/volume.png"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsMuted, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                            <Setter Property="Source" Value="/Resources/Icons/volume_mute.png"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DataContext.Volume, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                            <Setter Property="Source" Value="/Resources/Icons/volume_mute.png"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayerControlBarFullscreenButton" TargetType="Button" BasedOn="{StaticResource PlayerFullscreenButton}">
            <Setter Property="Margin" Value="{StaticResource ButtonGapLeft}"/>
            <Setter Property="Command" Value="{Binding ToggleFullscreenCommand}"/>
            <Setter Property="ToolTip"
                    Value="{Binding DataContext.Localization[Player.Fullscreen], RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            <Setter Property="Content" Value=""/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <Image Style="{StaticResource PlayerFullscreenButtonIcon}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                    <Setter Property="ToolTip"
                            Value="{Binding DataContext.Localization[Player.ExitFullscreen], RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <DataTemplate x:Key="PlayerSpeedOptionItemTemplate">
            <Button Style="{StaticResource PlayerControlBarSpeedOptionButton}"
                    Command="{Binding DataContext.ChangeSpeedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    Click="SpeedOption_Click">
                <TextBlock Text="{Binding StringFormat={}{0:0.0#}x}"
                           Style="{StaticResource PlayerSpeedOptionText}"/>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Height="{StaticResource ControlBarHeight}"
          Focusable="True">
        <Grid.Background>
            <StaticResource ResourceKey="ControlBarBackground"/>
        </Grid.Background>

        <Grid Margin="{StaticResource ControlBarHorizontalMargin}"
              VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <Button x:Name="PreviousBtn" Style="{StaticResource PlayerControlBarPreviousButton}"/>
                <Button x:Name="PlayPauseBtn" Style="{StaticResource PlayerControlBarPlayPauseButton}"/>
                <Button x:Name="NextBtn" Style="{StaticResource PlayerControlBarNextButton}"/>
                <Button x:Name="StopBtn" Style="{StaticResource PlayerControlBarStopButton}"/>
                <TextBlock Text="{Binding CurrentTimeText, FallbackValue='00:00'}"
                           Style="{StaticResource PlayerControlBarTimeText}"
                           Margin="{StaticResource TimeTextLeftMargin}"/>
                <TextBlock Text=" / "
                           Style="{StaticResource PlayerControlBarTimeSeparatorText}"/>
                <TextBlock Text="{Binding TotalTimeText, FallbackValue='00:00'}"
                           Style="{StaticResource PlayerControlBarTimeText}"/>
            </StackPanel>

            <primitives:SeekBar x:Name="SeekBar" Grid.Column="1"
                                Position="{Binding CurrentTime, Mode=OneWay}"
                                Duration="{Binding TotalTime}"
                                BufferedPosition="{Binding BufferedPosition}"
                                IsSeeking="{Binding IsSeeking, Mode=TwoWay}"
                                SeekCommand="{Binding SeekCommand}"
                                ThumbnailPreview="{Binding ThumbnailPreview}"
                                behaviors:HoverPopupBehavior.Controller="{Binding ThumbnailPreview.HoverPopupController}"
                                behaviors:HoverPopupBehavior.Zone="Host"
                                VerticalAlignment="Center"
                                ShowTooltip="False"
                                Margin="{StaticResource ControlBarSliderMargin}"/>

            <primitives:AnimatedPopup PlacementTarget="{Binding ElementName=SeekBar}"
                   PlacementPreset="Relative"
                   AllowsTransparency="True"
                   IsHitTestVisible="False"
                   StaysOpen="True"
                   IsOpenAnimated="{Binding ThumbnailPreview.IsOpen}"
                   OpenAnimationOrigin="0.5,1"
                   HorizontalOffset="{Binding ThumbnailPreview.HOffset}"
                   VerticalOffset="{Binding ThumbnailPreview.PopupVerticalOffset}">
                <Grid Width="{Binding ThumbnailPreview.PopupWidth}">
                    <Border x:Name="ThumbnailImageBorder"
                            Style="{StaticResource PlayerThumbnailPreviewImageBorder}"
                            behaviors:HoverPopupBehavior.Controller="{Binding ThumbnailPreview.HoverPopupController}"
                            behaviors:HoverPopupBehavior.Zone="Popup"
                            Visibility="{Binding ThumbnailPreview.ImageVisibility}">
                        <Image Source="{Binding ThumbnailPreview.ImageSource}"
                               Style="{StaticResource PlayerThumbnailPreviewImage}"/>
                    </Border>
                    <Border Style="{StaticResource PlayerThumbnailPreviewTimeBorder}"
                            behaviors:HoverPopupBehavior.Controller="{Binding ThumbnailPreview.HoverPopupController}"
                            behaviors:HoverPopupBehavior.Zone="Popup">
                        <TextBlock Text="{Binding ThumbnailPreview.TimeText}"
                                   Style="{StaticResource PlayerThumbnailPreviewTimeText}"/>
                    </Border>
                </Grid>
            </primitives:AnimatedPopup>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Grid>
                    <Button x:Name="SpeedBtn" Style="{StaticResource PlayerControlBarSpeedButton}"/>
                </Grid>

                <Button x:Name="VolumeBtn" Style="{StaticResource PlayerControlBarVolumeButton}"/>
                <Slider x:Name="VolumeSlider"
                        Style="{StaticResource PlayerControlBarVolumeSlider}"
                        Margin="{StaticResource VolumeSliderMargin}"
                        Value="{Binding Volume, Mode=OneWay}"
                        ValueChanged="VolumeSlider_ValueChanged"/>
                <Button x:Name="PlaylistToggleBtn" Style="{StaticResource PlayerControlBarPlaylistButton}"/>
                <Button x:Name="FullscreenBtn" Style="{StaticResource PlayerControlBarFullscreenButton}"/>
            </StackPanel>
        </Grid>

        <overlays:AnimatedOverlay x:Name="SpeedOverlay"
                                  Style="{StaticResource PlayerSpeedOverlay}"
                                  Panel.ZIndex="1000">
            <Border Style="{StaticResource PopupMenuOverlayBorder}"
                    MinWidth="{StaticResource SpeedPopupMinWidth}">
                <Grid>
                    <Border Style="{StaticResource PlayerSpeedOverlayHighlight}"
                            animations:SlideAnimator.TargetY="{Binding Rate, Converter={StaticResource RateToOffsetConverter}}">
                        <Border.RenderTransform>
                            <TranslateTransform Y="0"/>
                        </Border.RenderTransform>
                    </Border>
                    <ItemsControl ItemsSource="{Binding SpeedOptions}"
                                  ItemTemplate="{StaticResource PlayerSpeedOptionItemTemplate}"/>
                </Grid>
            </Border>
        </overlays:AnimatedOverlay>
    </Grid>
</UserControl>



