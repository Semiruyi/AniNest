<UserControl x:Class="AniNest.Features.Player.PlayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AniNest.Features.Player"
             xmlns:input="clr-namespace:AniNest.Presentation.Behaviors"
             xmlns:anim="clr-namespace:AniNest.Presentation.Animations"
             xmlns:conv="clr-namespace:AniNest.Presentation.Converters"
             xmlns:behaviors="clr-namespace:AniNest.Presentation.Behaviors"
             xmlns:primitives="clr-namespace:AniNest.Presentation.Primitives"
             Background="{StaticResource BackgroundDark}"
             Focusable="True"
             InputMethod.IsInputMethodEnabled="False"
             behaviors:LoadedCommandBehavior.FocusOnLoaded="True"
             input:PlayerInputBehavior.IsEnabled="True"
             >
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="PageRoot" anim:LoadedAnimator.Enabled="True"
          behaviors:MouseTrackBehavior.MouseMoveCommand="{Binding ControlBar.HandleMouseMoveCommand}"
          behaviors:MouseTrackBehavior.MouseLeaveCommand="{Binding ControlBar.HandleMouseLeaveCommand}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="VideoContainer" Grid.Row="0" Grid.Column="0" Background="Black">
            <Image x:Name="VideoImage" Stretch="Uniform" Source="{Binding VideoSource}"/>
            <Image x:Name="PauseBigIcon"
                   Source="/Resources/Icons/pause-big.png"
                   Width="{StaticResource PauseBigIconSize}"
                   Height="{StaticResource PauseBigIconSize}"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="{StaticResource PauseBigIconMargin}"
                   Opacity="0"
                   RenderTransformOrigin="0.5,0.5"
                   anim:PopupAnimator.BindVisible="{Binding IsPlaying, Converter={StaticResource InverseBool}}">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="PauseBigIconScale" ScaleX="0" ScaleY="0"/>
                </Image.RenderTransform>
            </Image>
        </Grid>

        <Border x:Name="PlaylistPanel" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Style="{StaticResource PlayerPlaylistPanelStyle}"
                DataContext="{Binding Playlist}"
                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="{StaticResource PlaylistHeaderMargin}">
                    <TextBlock Text="{Binding DataContext.Localization[Player.Playlist], RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Style="{StaticResource AppTextPanelTitle}"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EpisodeCountText, FallbackValue=''}"
                               Style="{StaticResource AppTextBody}"
                               Foreground="{StaticResource PlayerPlaylistMetaForeground}"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Episode Grid -->
                <ListBox Grid.Row="1"
                         Style="{StaticResource PlaylistEpisodeListBox}"
                         ItemsSource="{Binding Items}"
                         SelectedIndex="{Binding CurrentIndex, Mode=OneWay}">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource OverlayThinScrollBar}"/>
                    </ListBox.Resources>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <primitives:AnimatedWrapPanel Orientation="Horizontal"
                                                     AnimationDuration="0:0:0.2"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource PlayerEpisodeButton}"
                                    Command="{Binding DataContext.PlayEpisodeCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="{Binding Number, StringFormat={}{0:D2}}"
                                           Style="{StaticResource AppTextPanelValue}"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.ToolTip>
                                        <ToolTip Style="{StaticResource AppPanelToolTip}">
                                            <TextBlock Text="{Binding Title}" MaxWidth="220"
                                                       Style="{StaticResource AppTextBody}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <local:ControlBarView x:Name="ControlBar"
                              Grid.Column="0"
                              DataContext="{Binding ControlBar}">
            <UserControl.Style>
                <Style TargetType="local:ControlBarView">
                    <Setter Property="Grid.Row" Value="1"/>
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="IsHitTestVisible" Value="True"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                            <Setter Property="Grid.Row" Value="0"/>
                            <Setter Property="VerticalAlignment" Value="Bottom"/>
                            <Setter Property="Panel.ZIndex" Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsControlBarVisible}" Value="False">
                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.25"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </UserControl.Style>
        </local:ControlBarView>
    </Grid>
</UserControl>



