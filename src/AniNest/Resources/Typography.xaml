<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <FontFamily x:Key="AppFontFamily">Segoe UI, Microsoft YaHei UI, Microsoft YaHei</FontFamily>
    <system:Double x:Key="AppFontSizeCaption">12</system:Double>
    <system:Double x:Key="AppFontSizeBody">13</system:Double>
    <system:Double x:Key="AppFontSizeBodyStrong">14</system:Double>
    <system:Double x:Key="AppFontSizeTitleBar">14</system:Double>
    <system:Double x:Key="AppFontSizeSectionTitle">15</system:Double>
    <system:Double x:Key="AppFontSizePanelTitle">16</system:Double>
    <system:Double x:Key="AppFontSizePageTitle">20</system:Double>
    <system:Double x:Key="AppFontSizeThumbnailPreview">12</system:Double>
    <system:Double x:Key="AppFontSizeCardSummary">13</system:Double>

    <Style x:Key="AppTextCaption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeCaption}"/>
    </Style>

    <Style x:Key="AppTextBody" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeBody}"/>
    </Style>

    <Style x:Key="AppTextBodyStrong" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeBodyStrong}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="AppTextBodyEmphasis" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="AppTextSectionTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeSectionTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="AppTextPanelTitle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizePanelTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="AppTextPanelValue" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizePanelTitle}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <Style x:Key="AppTextTitleBar" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeTitleBar}"/>
    </Style>

    <Style x:Key="AppTextThumbnailPreview" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeThumbnailPreview}"/>
    </Style>

    <Style x:Key="AppTextCardSummary" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeCardSummary}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="LibraryCardTitleText" TargetType="TextBlock" BasedOn="{StaticResource AppTextSectionTitle}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="LibraryCardStatusText" TargetType="TextBlock" BasedOn="{StaticResource AppTextBody}">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="LibraryCardSummaryText" TargetType="TextBlock" BasedOn="{StaticResource AppTextCardSummary}">
        <Setter Property="Foreground" Value="{StaticResource LibraryCardInfoSecondaryText}"/>
    </Style>

    <Style x:Key="LibraryCardSummaryAccentText" TargetType="TextBlock" BasedOn="{StaticResource LibraryCardSummaryText}">
        <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
    </Style>

    <Style x:Key="LibraryCardSummaryMutedText" TargetType="TextBlock" BasedOn="{StaticResource LibraryCardSummaryText}">
        <Setter Property="Foreground" Value="{StaticResource LibraryCardInfoMutedText}"/>
    </Style>

    <Style x:Key="AppTooltipText" TargetType="ToolTip">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeBody}"/>
    </Style>

    <Style x:Key="AppTextIconPlaceholder" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="32"/>
    </Style>

    <Style x:Key="AppButtonTextCompact" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeCaption}"/>
    </Style>

    <Style x:Key="AppButtonTextCompactStrong" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeCaption}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="AppButtonTextPanelValue" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizePanelTitle}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

</ResourceDictionary>
