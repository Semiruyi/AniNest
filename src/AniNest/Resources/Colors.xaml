<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="AccentBlueColor">#FF007AFF</Color>
    <SolidColorBrush x:Key="AccentBlue" Color="{StaticResource AccentBlueColor}"/>
    <Color x:Key="AccentGreenColor">#FF2E9E57</Color>
    <SolidColorBrush x:Key="AccentGreen" Color="{StaticResource AccentGreenColor}"/>
    <Color x:Key="AccentRedColor">#FFD14B4B</Color>
    <SolidColorBrush x:Key="AccentRed" Color="{StaticResource AccentRedColor}"/>
    <Color x:Key="NeutralGrayColor">#FFAAAAAA</Color>
    <SolidColorBrush x:Key="NeutralGray" Color="{StaticResource NeutralGrayColor}"/>
    <Color x:Key="NeutralBlackColor">#FF000000</Color>
    <SolidColorBrush x:Key="NeutralBlack" Color="{StaticResource NeutralBlackColor}"/>

    <SolidColorBrush x:Key="BackgroundDark" Color="#FF1E1E1E"/>
    <SolidColorBrush x:Key="SurfaceOverlayDark" Color="#B8000000"/>
    <LinearGradientBrush x:Key="SurfaceOverlayDarkGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#00000000" Offset="0"/>
        <GradientStop Color="#B8000000" Offset="0.55"/>
        <GradientStop Color="#E6000000" Offset="1"/>
    </LinearGradientBrush>

    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#AAFFFFFF"/>

    <SolidColorBrush x:Key="PopupMenuBackground" Color="#E6282828"/>
    <SolidColorBrush x:Key="LibraryFilterBarBackground" Color="#B81A1A1A"/>
    <SolidColorBrush x:Key="LibraryFilterBarBorder" Color="#26FFFFFF"/>
    <SolidColorBrush x:Key="LibraryFilterBarItemHover" Color="#1FFFFFFF"/>
    <SolidColorBrush x:Key="LibraryFilterBarItemSelected" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="LibraryFavoriteColor" Color="#FFD7B24C"/>
    <SolidColorBrush x:Key="LibraryCardPlaceholderBackground" Color="#FF252525"/>
    <SolidColorBrush x:Key="LibraryCardInfoSecondaryText" Color="#BFC7D5"/>
    <SolidColorBrush x:Key="LibraryCardInfoMutedText" Color="#8A93A3"/>
    <SolidColorBrush x:Key="LibraryCardProgressTrack" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="LibraryStatusWatchingBackground" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="LibraryStatusUnsortedBackground" Color="{StaticResource NeutralBlackColor}"/>
    <SolidColorBrush x:Key="LibraryStatusCompletedBackground" Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="LibraryStatusDroppedBackground" Color="{StaticResource NeutralGrayColor}"/>
    <SolidColorBrush x:Key="PopupMenuDividerBrush" Color="#18FFFFFF"/>
    <SolidColorBrush x:Key="DangerForeground" Color="#FFFF7070"/>

    <SolidColorBrush x:Key="IconSecondary" Color="#AAAAAA"/>

    <SolidColorBrush x:Key="HoverBackground" Color="#22FFFFFF"/>
    <SolidColorBrush x:Key="PressedBackground" Color="#33FFFFFF"/>
    <Color x:Key="PressedBackgroundColor">#33FFFFFF</Color>

    <SolidColorBrush x:Key="ControlBarBackground" Color="#CC0F0F0F"/>
    <SolidColorBrush x:Key="ControlBarTimeSeparatorForeground" Color="#66FFFFFF"/>
    <SolidColorBrush x:Key="ProgressTrackBackground" Color="#33FFFFFF"/>
    <SolidColorBrush x:Key="ProgressBufferBackground" Color="#55FFFFFF"/>
    <SolidColorBrush x:Key="ProgressFillPrimary" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="ProgressFillWarning" Color="#FFF39C12"/>
    <SolidColorBrush x:Key="ProgressFillSuccess" Color="#FF2E7D32"/>

    <SolidColorBrush x:Key="PopupPanelBorderBrush" Color="#FF38383A"/>
    <SolidColorBrush x:Key="OverlayScrollbarThumbBackground" Color="#28FFFFFF"/>

    <SolidColorBrush x:Key="PlayerPlaylistPanelBackground" Color="#FF1A1A1C"/>
    <SolidColorBrush x:Key="PlayerPlaylistPanelBorder" Color="#FF222224"/>
    <SolidColorBrush x:Key="PlayerPlaylistMetaForeground" Color="#FF8E8E93"/>
    <SolidColorBrush x:Key="PlayerEpisodeForeground" Color="#FFEBEBF5"/>
    <Color x:Key="PlayerEpisodeBackgroundColor">#FF2C2C2E</Color>
    <SolidColorBrush x:Key="PlayerEpisodeBackground" Color="{StaticResource PlayerEpisodeBackgroundColor}"/>
    <Color x:Key="PlayerEpisodeHoverBackgroundColor">#FF3A3A3C</Color>
    <SolidColorBrush x:Key="PlayerEpisodeHoverBackground" Color="{StaticResource PlayerEpisodeHoverBackgroundColor}"/>
    <Color x:Key="PlayerEpisodePressedBackgroundColor">#FF1C1C1E</Color>
    <SolidColorBrush x:Key="PlayerEpisodePressedBackground" Color="{StaticResource PlayerEpisodePressedBackgroundColor}"/>
    <Color x:Key="PlayerEpisodePlayedBackgroundColor">#FF165396</Color>
    <SolidColorBrush x:Key="PlayerEpisodePlayedBackground" Color="{StaticResource PlayerEpisodePlayedBackgroundColor}"/>
    <SolidColorBrush x:Key="PlayerEpisodeThumbnailProgressBackground" Color="#FF48484A"/>

    <SolidColorBrush x:Key="CloseButtonHover" Color="#E81123"/>

    <SolidColorBrush x:Key="ThumbnailPreviewTimeBackground" Color="#99000000"/>

</ResourceDictionary>
