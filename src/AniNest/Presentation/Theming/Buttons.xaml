<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:animations="clr-namespace:AniNest.Presentation.Animations">

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource IconButtonDefault}"/>
        <Setter Property="Height" Value="{StaticResource IconButtonDefault}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="{StaticResource IconButtonOpacity}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Tag" Value="{StaticResource ButtonCornerRadius}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="ButtonGrid" RenderTransformOrigin="0.5,0.5"
                          Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="HoverBg" CornerRadius="{TemplateBinding Tag}"
                                Background="{DynamicResource HoverBackground}" Opacity="0"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AnimatedIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Default"/>
    </Style>

    <Style x:Key="AnimatedCompactIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Compact"/>
    </Style>

    <Style x:Key="AnimatedCompactRevealIconButton" TargetType="Button" BasedOn="{StaticResource AnimatedCompactIconButton}">
        <Setter Property="animations:ScaleFadeVisibilityAnimator.IsEnabled" Value="True"/>
        <Setter Property="animations:ScaleFadeVisibilityAnimator.Preset" Value="Compact"/>
    </Style>

    <Style x:Key="LibraryCardFavoriteButton" TargetType="Button" BasedOn="{StaticResource AnimatedCompactIconButton}">
        <Setter Property="Width" Value="28"/>
        <Setter Property="Height" Value="28"/>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="Background" Value="{StaticResource SurfaceOverlayDark}"/>
        <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Library.Favorite], RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="ButtonRoot"
                          Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Ellipse Fill="{TemplateBinding Background}"/>
                        <Ellipse x:Name="HoverBg"
                                 Fill="{DynamicResource HoverBackground}"
                                 Opacity="0"/>
                        <Grid Width="14"
                              Height="14"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="FavoriteIconScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Path x:Name="FavoriteFillIcon"
                                  Data="{StaticResource FavoriteIconGeometry}"
                                  Stretch="Uniform"
                                  Opacity="0">
                                <Path.Fill>
                                    <SolidColorBrush Color="#FFD7B24C"/>
                                </Path.Fill>
                            </Path>
                            <Path x:Name="FavoriteStrokeIcon"
                                  Data="{StaticResource FavoriteIconGeometry}"
                                  Stretch="Uniform"
                                  StrokeThickness="1.3"
                                  Fill="Transparent">
                                <Path.Stroke>
                                    <SolidColorBrush Color="#AAFFFFFF"/>
                                </Path.Stroke>
                            </Path>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="FavoriteStrokeIcon"
                                                        Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                        To="#FFD7B24C"
                                                        Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="FavoriteFillIcon"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.16"/>
                                        <DoubleAnimation Storyboard.TargetName="FavoriteIconScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0.86"
                                                         To="1"
                                                         Duration="0:0:0.20"/>
                                        <DoubleAnimation Storyboard.TargetName="FavoriteIconScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0.86"
                                                         To="1"
                                                         Duration="0:0:0.20"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="FavoriteStrokeIcon"
                                                        Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                        To="#AAFFFFFF"
                                                        Duration="0:0:0.16"/>
                                        <DoubleAnimation Storyboard.TargetName="FavoriteFillIcon"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.14"/>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FavoriteIconScale"
                                                                       Storyboard.TargetProperty="ScaleX">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.88"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FavoriteIconScale"
                                                                       Storyboard.TargetProperty="ScaleY">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.88"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                            <Setter TargetName="FavoriteFillIcon" Property="Opacity" Value="1"/>
                            <Setter TargetName="FavoriteStrokeIcon" Property="Stroke" Value="{StaticResource LibraryFavoriteColor}"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Library.Unfavorite], RelativeSource={RelativeSource AncestorType=UserControl}}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="AnimatedMenuButtonBase" TargetType="Button">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Menu"/>
    </Style>

    <Style x:Key="AnimatedCompactButtonBase" TargetType="Button">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Compact"/>
    </Style>

    <Style x:Key="MenuButtonBase" TargetType="Button" BasedOn="{StaticResource AnimatedMenuButtonBase}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeTitleBar}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BgBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding Tag}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBorder"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="Transparent"
                                                        Duration="0:0:0.2"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBorder"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="{StaticResource PressedBackgroundColor}"
                                                        Duration="0:0:0.1"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarIconButton" TargetType="Button" BasedOn="{StaticResource AnimatedCompactIconButton}">
        <Setter Property="Tag" Value="0"/>
    </Style>

    <Style x:Key="CloseIconButton" TargetType="Button" BasedOn="{StaticResource TitleBarIconButton}">
        <Style.Resources>
            <SolidColorBrush x:Key="HoverBackground" Color="#E81123"/>
        </Style.Resources>
    </Style>

    <Style x:Key="TitleBarMaximizeButton" TargetType="Button" BasedOn="{StaticResource TitleBarIconButton}">
        <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Window.Maximize], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <Style.Triggers>
            <DataTrigger Value="Maximized"
                         Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Window.Restore], RelativeSource={RelativeSource AncestorType=Window}}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TitleBarMaximizeIconPath" TargetType="Path">
        <Setter Property="Data" Value="{StaticResource MaximizeIconGeometry}"/>
        <Style.Triggers>
            <DataTrigger Value="Maximized"
                         Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                <Setter Property="Data" Value="{StaticResource RestoreIconGeometry}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TitleBarActionButton" TargetType="Button" BasedOn="{StaticResource TitleBarTextButton}">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Compact"/>
    </Style>

    <Style x:Key="PopupMenuButton" TargetType="Button" BasedOn="{StaticResource MenuButtonBase}">
        <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PopupMenuButtonPadding}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Tag" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
    </Style>

    <Style x:Key="SelectableOptionButtonBase" TargetType="Button" BasedOn="{StaticResource MenuButtonBase}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="animations:SelectableOptionState.IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SelectableOptionMenuButton" TargetType="Button" BasedOn="{StaticResource SelectableOptionButtonBase}">
        <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PopupMenuButtonPadding}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="Tag" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
    </Style>

    <Style x:Key="SelectableOptionSegmentButton" TargetType="Button" BasedOn="{StaticResource SelectableOptionButtonBase}">
        <Setter Property="Height" Value="{StaticResource LibraryFilterBarItemHeight}"/>
        <Setter Property="MinWidth" Value="{StaticResource LibraryFilterBarItemMinWidth}"/>
        <Setter Property="Padding" Value="{StaticResource LibraryFilterBarItemPadding}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="Tag" Value="{StaticResource LibraryFilterBarItemCornerRadius}"/>
    </Style>

</ResourceDictionary>
