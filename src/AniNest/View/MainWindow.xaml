<Window x:Class="AniNest.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:AniNest.Presentation.Behaviors"
        xmlns:local="clr-namespace:AniNest.View"
        xmlns:primitives="clr-namespace:AniNest.Presentation.Primitives"
        xmlns:overlays="clr-namespace:AniNest.Presentation.Overlays"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:animations="clr-namespace:AniNest.Presentation.Animations"
        Title="AniNest"
        Icon="/Resources/Icons/App.ico"
        Height="{StaticResource WindowDefaultHeight}"
        Width="{StaticResource WindowDefaultWidth}"
        MinWidth="{StaticResource WindowMinWidth}"
        MinHeight="{StaticResource WindowMinHeight}"
        Background="{StaticResource TransparentBrush}"
        InputMethod.IsInputMethodEnabled="False"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{StaticResource TitleBarHeight}"
                            ResizeBorderThickness="{StaticResource WindowResizeBorderThickness}"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder"
            ClipToBounds="True"
            Background="{StaticResource BackgroundDark}"
            Style="{StaticResource MainWindowRootBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TitleBarRow" Height="{StaticResource TitleBarRowHeight}"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <local:MainWindowTitleBar x:Name="TitleBarView"
                                      Grid.Row="0"/>

            <overlays:AnimatedOverlay x:Name="SettingsOverlay"
                                      Style="{StaticResource MainWindowBottomMenuOverlay}"
                                      Panel.ZIndex="2001">
                                <Border Style="{StaticResource MainWindowSettingsMenuBorder}">
                                    <StackPanel Style="{StaticResource PopupMenuPanel}">
                                        <Grid Style="{StaticResource PopupMenuButtonHost}">
                                            <Button x:Name="LanguageMenuButton"
                                                    Style="{StaticResource MainWindowSubmenuButton}"
                                                    Content="{Binding DataContext.Localization[Settings.Language], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Click="LanguageMenuButton_Click"/>
                                        </Grid>
                                        <Grid Style="{StaticResource PopupMenuButtonHost}">
                                            <Button x:Name="FullscreenAnimationMenuButton"
                                                    Style="{StaticResource MainWindowSubmenuButton}"
                                                    Content="{Binding DataContext.Localization[Settings.FullscreenAnimation], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    ToolTip="{Binding DataContext.Localization[Settings.FullscreenAnimation.Tooltip], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Click="FullscreenAnimationMenuButton_Click"/>
                                        </Grid>
                                        <Grid Style="{StaticResource PopupMenuButtonHost}">
                                            <Button x:Name="ThumbnailSettingsMenuButton"
                                                    Style="{StaticResource MainWindowSubmenuButton}"
                                                    Content="{Binding DataContext.Localization[Settings.Thumbnails], RelativeSource={RelativeSource AncestorType=Window}}"
                                                    Click="ThumbnailSettingsMenuButton_Click"/>
                                        </Grid>
                                        <Grid Style="{StaticResource PopupMenuButtonHost}">
                                            <Button x:Name="PlayerInputMenuButton"
                                                    Style="{StaticResource MainWindowSubmenuButton}"
                                                    Content="{Binding PlayerInputSettings.Title}"
                                                    Click="PlayerInputMenuButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
            </overlays:AnimatedOverlay>

            <overlays:AnimatedOverlay x:Name="LanguageOverlay"
                                      Style="{StaticResource MainWindowRightSubmenuOverlay}"
                                      Panel.ZIndex="2002">
                <Border Style="{StaticResource MainWindowSubmenuMenuBorder}">
                    <primitives:SelectableOptionGroup x:Name="LanguageOptionGroup"
                                                      Style="{StaticResource SelectableOptionMenuGroup}"
                                                      SelectedIndex="{Binding DataContext.LanguageSelectedIndex, RelativeSource={RelativeSource AncestorType=Window}}">
                        <ItemsControl x:Name="LanguageOptionsPanel"
                                      ItemsSource="{Binding DataContext.LanguageOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                      ItemTemplate="{StaticResource LanguageOverlayItemTemplate}"/>
                    </primitives:SelectableOptionGroup>
                </Border>
            </overlays:AnimatedOverlay>

            <overlays:AnimatedOverlay x:Name="FullscreenAnimationOverlay"
                                      Style="{StaticResource MainWindowRightSubmenuOverlay}"
                                      Panel.ZIndex="2003">
                <Border Style="{StaticResource MainWindowSubmenuMenuBorder}">
                    <primitives:SelectableOptionGroup x:Name="FullscreenAnimationOptionGroup"
                                                      Style="{StaticResource SelectableOptionMenuGroup}"
                                                      SelectedIndex="{Binding DataContext.FullscreenAnimationSelectedIndex, RelativeSource={RelativeSource AncestorType=Window}}">
                        <ItemsControl x:Name="FullscreenAnimationOptionsPanel"
                                      ItemsSource="{Binding DataContext.FullscreenAnimationOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                      ItemTemplate="{StaticResource FullscreenAnimationOverlayItemTemplate}"/>
                    </primitives:SelectableOptionGroup>
                </Border>
            </overlays:AnimatedOverlay>

            <overlays:AnimatedOverlay x:Name="ThumbnailSettingsOverlay"
                                      Style="{StaticResource MainWindowRightSubmenuOverlay}"
                                      Panel.ZIndex="2004">
                <Border Style="{StaticResource MainWindowSubmenuMenuBorder}">
                    <StackPanel Style="{StaticResource PopupMenuPanel}">
                        <Button x:Name="ThumbnailPerformanceMenuButton"
                                Style="{StaticResource MainWindowSummarySubmenuButton}"
                                Content="{Binding DataContext.Localization[Settings.ThumbnailPerformance], RelativeSource={RelativeSource AncestorType=Window}}"
                                behaviors:MenuVisualBehavior.SummaryText="{Binding DataContext.ThumbnailPerformanceSummary, RelativeSource={RelativeSource AncestorType=Window}}"
                                Click="ThumbnailPerformanceMenuButton_Click"/>
                        <Button x:Name="ThumbnailAccelerationMenuButton"
                                Style="{StaticResource MainWindowSummarySubmenuButton}"
                                Content="{Binding DataContext.Localization[Settings.ThumbnailAcceleration], RelativeSource={RelativeSource AncestorType=Window}}"
                                behaviors:MenuVisualBehavior.SummaryText="{Binding DataContext.ThumbnailAccelerationSummary, RelativeSource={RelativeSource AncestorType=Window}}"
                                Click="ThumbnailAccelerationMenuButton_Click"/>
                    </StackPanel>
                </Border>
            </overlays:AnimatedOverlay>

            <overlays:AnimatedOverlay x:Name="ThumbnailPerformanceOverlay"
                                      Style="{StaticResource MainWindowRightSubmenuOverlay}"
                                      Panel.ZIndex="2005">
                <Border Style="{StaticResource MainWindowThumbnailPerformanceMenuBorder}">
                    <StackPanel Style="{StaticResource PopupMenuPanel}">
                        <Grid Style="{StaticResource PopupMenuOptionGroupHost}">
                            <primitives:SelectableOptionGroup x:Name="ThumbnailPerformanceOptionGroup"
                                                              Style="{StaticResource SelectableOptionMenuGroup}"
                                                              SelectedIndex="{Binding DataContext.ThumbnailPerformanceSelectedIndex, RelativeSource={RelativeSource AncestorType=Window}}">
                                <StackPanel x:Name="ThumbnailPerformanceOptionsPanel"
                                            Style="{StaticResource PopupMenuOptionListPanel}">
                                    <Button Style="{StaticResource ThumbnailPerformanceOptionButton}"
                                            animations:SelectableOptionState.IsSelected="{Binding DataContext.IsThumbnailPerformancePausedSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Command="{Binding DataContext.SelectThumbnailPerformanceModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="paused"
                                            IsEnabled="{Binding DataContext.CanSelectThumbnailPerformanceMode, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <TextBlock Text="{Binding DataContext.Localization[Settings.ThumbnailPerformance.Paused], RelativeSource={RelativeSource AncestorType=Window}}"
                                                   Style="{StaticResource PopupMenuItemText}"/>
                                    </Button>
                                    <Button Style="{StaticResource ThumbnailPerformanceOptionButton}"
                                            animations:SelectableOptionState.IsSelected="{Binding DataContext.IsThumbnailPerformanceQuietSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Command="{Binding DataContext.SelectThumbnailPerformanceModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="quiet"
                                            IsEnabled="{Binding DataContext.CanSelectThumbnailPerformanceMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTip="{Binding DataContext.Localization[Settings.ThumbnailPerformance.Quiet.Tooltip], RelativeSource={RelativeSource AncestorType=Window}}">
                                        <TextBlock Text="{Binding DataContext.Localization[Settings.ThumbnailPerformance.Quiet], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource PopupMenuItemText}"/>
                                    </Button>
                                    <Button Style="{StaticResource ThumbnailPerformanceOptionButton}"
                                            animations:SelectableOptionState.IsSelected="{Binding DataContext.IsThumbnailPerformanceBalancedSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Command="{Binding DataContext.SelectThumbnailPerformanceModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="balanced"
                                            IsEnabled="{Binding DataContext.CanSelectThumbnailPerformanceMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTip="{Binding DataContext.Localization[Settings.ThumbnailPerformance.Balanced.Tooltip], RelativeSource={RelativeSource AncestorType=Window}}">
                                        <TextBlock Text="{Binding DataContext.Localization[Settings.ThumbnailPerformance.Balanced], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource PopupMenuItemText}"/>
                                    </Button>
                                    <Button Style="{StaticResource ThumbnailPerformanceOptionButton}"
                                            animations:SelectableOptionState.IsSelected="{Binding DataContext.IsThumbnailPerformanceFastSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Command="{Binding DataContext.SelectThumbnailPerformanceModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="fast"
                                            IsEnabled="{Binding DataContext.CanSelectThumbnailPerformanceMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                            ToolTip="{Binding DataContext.Localization[Settings.ThumbnailPerformance.Fast.Tooltip], RelativeSource={RelativeSource AncestorType=Window}}">
                                        <TextBlock Text="{Binding DataContext.Localization[Settings.ThumbnailPerformance.Fast], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource PopupMenuItemText}"/>
                                    </Button>
                                </StackPanel>
                            </primitives:SelectableOptionGroup>
                        </Grid>
                    </StackPanel>
                </Border>
            </overlays:AnimatedOverlay>

            <overlays:AnimatedOverlay x:Name="ThumbnailAccelerationOverlay"
                                      Style="{StaticResource MainWindowRightSubmenuOverlay}"
                                      Panel.ZIndex="2006">
                <Border Style="{StaticResource MainWindowThumbnailAccelerationMenuBorder}">
                    <StackPanel Style="{StaticResource PopupMenuPanel}">
                        <primitives:SelectableOptionGroup x:Name="ThumbnailAccelerationOptionGroup"
                                                          Style="{StaticResource SelectableOptionMenuGroup}"
                                                          SelectedIndex="{Binding DataContext.ThumbnailAccelerationSelectedIndex, RelativeSource={RelativeSource AncestorType=Window}}">
                            <StackPanel x:Name="ThumbnailAccelerationOptionsPanel"
                                        Style="{StaticResource PopupMenuOptionListPanel}">
                                <Button Style="{StaticResource ThumbnailAccelerationOptionButton}"
                                        animations:SelectableOptionState.IsSelected="{Binding DataContext.IsThumbnailAccelerationAutoSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Command="{Binding DataContext.SelectThumbnailAccelerationModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="auto"
                                        ToolTip="{Binding DataContext.Localization[Settings.ThumbnailAcceleration.Auto.Tooltip], RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock Text="{Binding DataContext.Localization[Settings.ThumbnailAcceleration.Auto], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource PopupMenuItemText}"/>
                                </Button>
                                <Button Style="{StaticResource ThumbnailAccelerationOptionButton}"
                                        animations:SelectableOptionState.IsSelected="{Binding DataContext.IsThumbnailAccelerationCompatibleSelected, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Command="{Binding DataContext.SelectThumbnailAccelerationModeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="compatible"
                                        ToolTip="{Binding DataContext.Localization[Settings.ThumbnailAcceleration.Compatible.Tooltip], RelativeSource={RelativeSource AncestorType=Window}}">
                                    <TextBlock Text="{Binding DataContext.Localization[Settings.ThumbnailAcceleration.Compatible], RelativeSource={RelativeSource AncestorType=Window}}" Style="{StaticResource PopupMenuItemText}"/>
                                </Button>
                            </StackPanel>
                        </primitives:SelectableOptionGroup>

                        <Border Style="{StaticResource AppInsetPanelBorder}"
                                Margin="{StaticResource OverlayInsetSectionMargin}">
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.Localization[Settings.ThumbnailAcceleration.Status], RelativeSource={RelativeSource AncestorType=Window}}"
                                           Style="{StaticResource OverlaySectionTitleText}"
                                           Margin="{StaticResource OverlaySectionTitleMargin}"/>
                                <TextBlock Style="{StaticResource OverlaySecondaryItemText}">
                                    <Run Text="{Binding DataContext.Localization[Settings.ThumbnailAcceleration.Hardware], RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding DataContext.ThumbnailDetectedHardwareSummary, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource OverlaySecondaryItemText}">
                                    <Run Text="{Binding DataContext.Localization[Settings.ThumbnailAcceleration.CurrentDecoder], RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding DataContext.ThumbnailCurrentDecoderSummary, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource OverlaySecondaryBlockText}">
                                    <Run Text="{Binding DataContext.Localization[Settings.ThumbnailAcceleration.FallbackChain], RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                                    <Run Text=": "/>
                                    <Run Text="{Binding DataContext.ThumbnailFallbackChainSummary, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </overlays:AnimatedOverlay>

            <overlays:AnimatedOverlay x:Name="PlayerInputOverlay"
                                      Style="{StaticResource MainWindowRightCaptureOverlay}"
                                      Panel.ZIndex="2007">
                <Border Style="{StaticResource MainWindowPanelOverlayBorder}"
                        MinWidth="{StaticResource PlayerInputPopupMinWidth}">
                    <Grid DataContext="{Binding PlayerInputSettings}"
                          Style="{StaticResource PlayerInputOverlayLayoutGrid}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding HintText}"
                                   Style="{StaticResource PlayerInputHintText}"/>
                        <ScrollViewer Grid.Row="1"
                                      Style="{StaticResource PlayerInputScrollViewer}">
                            <ItemsControl ItemsSource="{Binding Items}"
                                          ItemTemplate="{StaticResource PlayerInputBindingItemTemplate}"/>
                        </ScrollViewer>
                        <Button Grid.Row="2"
                                Style="{StaticResource PlayerInputResetButton}"
                                Command="{Binding ResetCommand}">
                            <TextBlock Text="{Binding ResetButtonText}"
                                       Style="{StaticResource PlayerInputButtonText}"/>
                        </Button>
                    </Grid>
                </Border>
            </overlays:AnimatedOverlay>

            <overlays:AnimatedOverlay x:Name="FileOverlay"
                                      Style="{StaticResource MainWindowBottomMenuOverlay}"
                                      Panel.ZIndex="2000">
                <Border Style="{StaticResource MainWindowFileMenuBorder}">
                    <StackPanel Style="{StaticResource PopupMenuPanel}">
                        <Button Style="{StaticResource MainWindowIconMenuButton}"
                                Command="{Binding AddFolderCommand}"
                                Content="{Binding DataContext.Localization[App.AddFolder], RelativeSource={RelativeSource AncestorType=Window}}"
                                behaviors:MenuVisualBehavior.IconData="M10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6H12L10 4Z"
                                Click="OnFileOverlayActionClick"/>
                        <Button Style="{StaticResource MainWindowIconMenuButton}"
                                Command="{Binding AddFolderBatchCommand}"
                                Content="{Binding DataContext.Localization[App.AddFolderBatch], RelativeSource={RelativeSource AncestorType=Window}}"
                                behaviors:MenuVisualBehavior.IconData="M10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6H12L10 4Z M17 13H13V17H11V13H7V11H11V7H13V11H17V13Z"
                                Click="OnFileOverlayActionClick"/>
                    </StackPanel>
                </Border>
            </overlays:AnimatedOverlay>

            <primitives:TransitioningContentControl x:Name="PageTransition"
                Grid.Row="1" Content="{Binding CurrentPage}"/>
        </Grid>
    </Border>
</Window>



