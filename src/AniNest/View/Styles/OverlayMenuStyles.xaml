<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <Style x:Key="PopupMenuChevronIcon" TargetType="Path">
        <Setter Property="Data" Value="{StaticResource ChevronRightGeometry}"/>
        <Setter Property="Fill" Value="{StaticResource IconSecondary}"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Width" Value="{StaticResource SubmenuChevronWidth}"/>
        <Setter Property="Height" Value="{StaticResource SubmenuChevronHeight}"/>
        <Setter Property="Margin" Value="{StaticResource SubmenuChevronLeftMargin}"/>
    </Style>

    <Style x:Key="PopupMenuSubmenuButton" TargetType="Button" BasedOn="{StaticResource PopupMenuButton}">
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="PopupMenuOverlayButton" TargetType="Button" BasedOn="{StaticResource PopupMenuButton}">
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="SelectableOptionOverlayMenuButton" TargetType="Button" BasedOn="{StaticResource SelectableOptionMenuButton}">
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="PopupMenuPanel" TargetType="StackPanel">
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="PopupMenuButtonHost" TargetType="Grid">
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="PopupMenuOptionGroupHost" TargetType="Grid">
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="PopupMenuOptionListPanel" TargetType="StackPanel">
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="PopupMenuHorizontalContentPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
    </Style>

    <Style x:Key="PopupMenuItemText" TargetType="TextBlock" BasedOn="{StaticResource AppTextBody}">
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PopupMenuDangerText" TargetType="TextBlock" BasedOn="{StaticResource PopupMenuItemText}">
        <Setter Property="Foreground" Value="{StaticResource DangerForeground}"/>
    </Style>

    <Style x:Key="PopupMenuItemIcon" TargetType="Path">
        <Setter Property="Fill" Value="{StaticResource IconSecondary}"/>
        <Setter Property="Width" Value="{StaticResource IconSizeNormal}"/>
        <Setter Property="Height" Value="{StaticResource IconSizeNormal}"/>
        <Setter Property="Stretch" Value="Uniform"/>
        <Setter Property="Margin" Value="{StaticResource PopupMenuItemIconMargin}"/>
    </Style>

    <Style x:Key="PopupMenuOverlayBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource PopupMenuBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PopupPanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource SpeedPopupCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource PopupMenuPadding}"/>
        <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
    </Style>

    <Style x:Key="PopupPanelBorder" TargetType="Border" BasedOn="{StaticResource PopupMenuOverlayBorder}">
        <Setter Property="Padding" Value="{StaticResource PopupPanelPadding}"/>
    </Style>

    <Style x:Key="PopupPanelCompactBorder" TargetType="Border" BasedOn="{StaticResource PopupMenuOverlayBorder}">
        <Setter Property="Padding" Value="{StaticResource PopupPanelCompactPadding}"/>
    </Style>

    <Style x:Key="OverlaySecondaryText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeBody}"/>
    </Style>

    <Style x:Key="OverlaySecondaryItemText" TargetType="TextBlock" BasedOn="{StaticResource OverlaySecondaryText}">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="{StaticResource OverlaySecondaryItemMargin}"/>
    </Style>

    <Style x:Key="OverlaySecondaryBlockText" TargetType="TextBlock" BasedOn="{StaticResource OverlaySecondaryText}">
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="OverlaySummaryText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeBody}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
    </Style>

    <Style x:Key="OverlaySummaryLabelText" TargetType="TextBlock" BasedOn="{StaticResource OverlaySummaryText}">
        <Setter Property="Margin" Value="{StaticResource OverlaySummaryMargin}"/>
    </Style>

    <Style x:Key="OverlaySectionTitleText" TargetType="TextBlock" BasedOn="{StaticResource AppTextCaption}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

</ResourceDictionary>
