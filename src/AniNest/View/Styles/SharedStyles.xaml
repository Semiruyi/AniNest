<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:animations="clr-namespace:AniNest.Presentation.Animations"
                    xmlns:primitives="clr-namespace:AniNest.Presentation.Primitives"
                    xmlns:overlays="clr-namespace:AniNest.Presentation.Overlays"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource IconButtonDefault}"/>
        <Setter Property="Height" Value="{StaticResource IconButtonDefault}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="{StaticResource IconButtonOpacity}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Tag" Value="{StaticResource ButtonCornerRadius}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="ButtonGrid" RenderTransformOrigin="0.5,0.5"
                          Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="HoverBg" CornerRadius="{TemplateBinding Tag}"
                                Background="{DynamicResource HoverBackground}" Opacity="0"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AnimatedIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Default"/>
    </Style>

    <Style x:Key="AnimatedCompactIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Compact"/>
    </Style>

    <Style x:Key="AnimatedMenuButtonBase" TargetType="Button">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Menu"/>
    </Style>

    <Style x:Key="AnimatedCompactButtonBase" TargetType="Button">
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.Preset" Value="Compact"/>
    </Style>

    <Style x:Key="MenuButtonBase" TargetType="Button" BasedOn="{StaticResource AnimatedMenuButtonBase}">
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeTitleBar}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BgBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding Tag}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBorder"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="Transparent"
                                                        Duration="0:0:0.2"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBorder"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="{StaticResource PressedBackgroundColor}"
                                                        Duration="0:0:0.1"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarIconButton" TargetType="Button" BasedOn="{StaticResource AnimatedCompactIconButton}">
        <Setter Property="Tag" Value="0"/>
    </Style>

    <Style x:Key="CloseIconButton" TargetType="Button" BasedOn="{StaticResource TitleBarIconButton}">
        <Style.Resources>
            <SolidColorBrush x:Key="HoverBackground" Color="#E81123"/>
        </Style.Resources>
    </Style>

    <Style x:Key="TitleBarMaximizeButton" TargetType="Button" BasedOn="{StaticResource TitleBarIconButton}">
        <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Window.Maximize], RelativeSource={RelativeSource AncestorType=Window}}"/>
        <Style.Triggers>
            <DataTrigger Value="Maximized"
                         Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Window.Restore], RelativeSource={RelativeSource AncestorType=Window}}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TitleBarMaximizeIconPath" TargetType="Path">
        <Setter Property="Data" Value="{StaticResource MaximizeIconGeometry}"/>
        <Style.Triggers>
            <DataTrigger Value="Maximized"
                         Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                <Setter Property="Data" Value="{StaticResource RestoreIconGeometry}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="TitleBarTextButton" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource TitleBarButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource TitleBarTextButtonPadding}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Opacity" Value="{StaticResource TitleBarTextOpacity}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeTitleBar}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="HoverBg" CornerRadius="0"
                                Background="{StaticResource PressedBackground}" Opacity="0"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PopupMenuButton" TargetType="Button" BasedOn="{StaticResource MenuButtonBase}">
        <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PopupMenuButtonPadding}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Tag" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
    </Style>

    <Style x:Key="SelectableOptionButtonBase" TargetType="Button" BasedOn="{StaticResource MenuButtonBase}">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Style.Triggers>
            <Trigger Property="animations:SelectableOptionState.IsSelected" Value="True">
                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                <Setter Property="FontWeight" Value="Bold"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SelectableOptionMenuButton" TargetType="Button" BasedOn="{StaticResource SelectableOptionButtonBase}">
        <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PopupMenuButtonPadding}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="Tag" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
    </Style>

    <Style x:Key="SelectableOptionSegmentButton" TargetType="Button" BasedOn="{StaticResource SelectableOptionButtonBase}">
        <Setter Property="Height" Value="{StaticResource LibraryFilterBarItemHeight}"/>
        <Setter Property="MinWidth" Value="{StaticResource LibraryFilterBarItemMinWidth}"/>
        <Setter Property="Padding" Value="{StaticResource LibraryFilterBarItemPadding}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="Tag" Value="{StaticResource LibraryFilterBarItemCornerRadius}"/>
    </Style>

    <Style x:Key="SelectableOptionMenuHighlight" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
        <Setter Property="CornerRadius" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
        <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="SelectableOptionSegmentHighlight" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LibraryFilterBarItemSelected}"/>
        <Setter Property="CornerRadius" Value="{StaticResource LibraryFilterBarItemCornerRadius}"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="SelectableOptionGroupBase" TargetType="{x:Type primitives:SelectableOptionGroup}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:SelectableOptionGroup}">
                    <Grid>
                        <Border Style="{TemplateBinding HighlightStyle}"
                                animations:FadeVisibilityAnimator.BindVisible="{Binding IsSelectionHighlightActive, RelativeSource={RelativeSource TemplatedParent}}"
                                animations:FadeVisibilityAnimator.Preset="Default"
                                animations:SelectionHighlightAnimation.IsEnabled="{Binding IsSelectionHighlightActive, RelativeSource={RelativeSource TemplatedParent}}"
                                animations:SelectionHighlightAnimation.Target="{Binding ElementName=PART_ContentHost}"
                                animations:SelectionHighlightAnimation.SelectedIndex="{Binding SelectedIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <ContentPresenter x:Name="PART_ContentHost"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SelectableOptionMenuGroup" TargetType="{x:Type primitives:SelectableOptionGroup}" BasedOn="{StaticResource SelectableOptionGroupBase}">
        <Setter Property="HighlightStyle" Value="{StaticResource SelectableOptionMenuHighlight}"/>
    </Style>

    <Style x:Key="SelectableOptionSegmentGroup" TargetType="{x:Type primitives:SelectableOptionGroup}" BasedOn="{StaticResource SelectableOptionGroupBase}">
        <Setter Property="HighlightStyle" Value="{StaticResource SelectableOptionSegmentHighlight}"/>
    </Style>

    <Style x:Key="DeleteIconButton" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource DeleteButtonSize}"/>
        <Setter Property="Height" Value="{StaticResource DeleteButtonSize}"/>
        <Setter Property="Background" Value="{StaticResource DeleteButtonBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse Fill="{TemplateBinding Background}"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppProgressBarThin" TargetType="ProgressBar">
        <Setter Property="Height" Value="{StaticResource ProgressBarThinHeight}"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
        <Setter Property="Foreground" Value="{StaticResource ProgressFillPrimary}"/>
        <Setter Property="Background" Value="{StaticResource ProgressTrackBackground}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ProgressBarThinCornerRadius}">
                        <Grid x:Name="PART_Track"
                              ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource ProgressBarThinCornerRadius}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppProgressBarMedium" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarThin}">
        <Setter Property="Height" Value="{StaticResource ProgressBarMediumHeight}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ProgressBarMediumCornerRadius}">
                        <Grid x:Name="PART_Track"
                              ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource ProgressBarMediumCornerRadius}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppProgressBarThinWarning" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarThin}">
        <Setter Property="Foreground" Value="{StaticResource ProgressFillWarning}"/>
    </Style>

    <Style x:Key="AppProgressBarThinSuccess" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarThin}">
        <Setter Property="Foreground" Value="{StaticResource ProgressFillSuccess}"/>
    </Style>

    <Style x:Key="AppProgressBarMediumWarning" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarMedium}">
        <Setter Property="Foreground" Value="{StaticResource ProgressFillWarning}"/>
    </Style>

    <Style x:Key="AppProgressBarMediumSuccess" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarMedium}">
        <Setter Property="Foreground" Value="{StaticResource ProgressFillSuccess}"/>
    </Style>

    <Style TargetType="{x:Type overlays:AnimatedOverlay}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type overlays:AnimatedOverlay}">
                    <Grid Background="{x:Null}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Border x:Name="PART_PositionHost"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="{TemplateBinding SurfaceMargin}"
                                Background="Transparent"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Border x:Name="PART_Surface"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                Opacity="0"
                                RenderTransformOrigin="{TemplateBinding AnimationOrigin}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                            </Border>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

