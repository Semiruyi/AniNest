<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:animations="clr-namespace:AniNest.Presentation.Animations"
                    xmlns:overlays="clr-namespace:AniNest.Presentation.Overlays"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource IconButtonDefault}"/>
        <Setter Property="Height" Value="{StaticResource IconButtonDefault}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="{StaticResource IconButtonOpacity}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="ButtonGrid" RenderTransformOrigin="0.5,0.5"
                          Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="HoverBg" CornerRadius="{DynamicResource ButtonCornerRadius}"
                                Background="{DynamicResource HoverBackground}" Opacity="0"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TitleBarIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Style.Resources>
            <CornerRadius x:Key="ButtonCornerRadius">0</CornerRadius>
        </Style.Resources>
    </Style>

    <Style x:Key="CloseIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Style.Resources>
            <SolidColorBrush x:Key="HoverBackground" Color="#E81123"/>
            <CornerRadius x:Key="ButtonCornerRadius">0</CornerRadius>
        </Style.Resources>
    </Style>

    <Style x:Key="TitleBarTextButton" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource TitleBarButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource TitleBarTextButtonPadding}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Opacity" Value="{StaticResource TitleBarTextOpacity}"/>
        <Setter Property="FontSize" Value="{StaticResource TitleBarTextFontSize}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="HoverBg" CornerRadius="0"
                                Background="{StaticResource PressedBackground}" Opacity="0"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PopupMenuButton" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
        <Setter Property="Padding" Value="{StaticResource PopupMenuButtonPadding}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="FontSize" Value="{StaticResource TitleBarTextFontSize}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="animations:ButtonScaleHover.IsEnabled" Value="True"/>
        <Setter Property="animations:ButtonScaleHover.HoverScaleEnabled" Value="False"/>
        <Setter Property="animations:ButtonScaleHover.PressScale" Value="0.96"/>
        <Setter Property="animations:ButtonScaleHover.PressDurationMs" Value="80"/>
        <Setter Property="animations:ButtonScaleHover.ReleaseDurationMs" Value="250"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BgBorder"
                            CornerRadius="{StaticResource PopupMenuButtonCornerRadius}"
                            Background="Transparent"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBorder"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="Transparent"
                                                        Duration="0:0:0.2"/>
                                    </Storyboard>
                                </VisualState>
                                <VisualState Name="MouseOver">
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BgBorder"
                                                        Storyboard.TargetProperty="Background.Color"
                                                        To="{StaticResource PressedBackgroundColor}"
                                                        Duration="0:0:0.1"/>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DeleteIconButton" TargetType="Button">
        <Setter Property="Width" Value="{StaticResource DeleteButtonSize}"/>
        <Setter Property="Height" Value="{StaticResource DeleteButtonSize}"/>
        <Setter Property="Background" Value="{StaticResource DeleteButtonBackground}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse Fill="{TemplateBinding Background}"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type overlays:AnimatedOverlay}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type overlays:AnimatedOverlay}">
                    <Grid Background="{x:Null}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Border x:Name="PART_PositionHost"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="{TemplateBinding SurfaceMargin}"
                                Background="Transparent"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Border x:Name="PART_Surface"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="Transparent"
                                Opacity="0"
                                RenderTransformOrigin="{TemplateBinding AnimationOrigin}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                            </Border>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

