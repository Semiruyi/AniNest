<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:animations="clr-namespace:AniNest.Presentation.Animations"
                    xmlns:behaviors="clr-namespace:AniNest.Presentation.Behaviors"
                    xmlns:primitives="clr-namespace:AniNest.Presentation.Primitives"
                    xmlns:overlays="clr-namespace:AniNest.Presentation.Overlays"
                    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">

    <Style x:Key="TitleBarTextButton" TargetType="Button">
        <Setter Property="Height" Value="{StaticResource TitleBarButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource TitleBarTextButtonPadding}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Opacity" Value="{StaticResource TitleBarTextOpacity}"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeTitleBar}"/>
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="HoverBg" CornerRadius="0"
                                Background="{StaticResource PressedBackground}" Opacity="0"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SelectableOptionMenuHighlight" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
        <Setter Property="CornerRadius" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
        <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="SelectableOptionSegmentHighlight" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LibraryFilterBarItemSelected}"/>
        <Setter Property="CornerRadius" Value="{StaticResource LibraryFilterBarItemCornerRadius}"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="SelectableOptionGroupBase" TargetType="{x:Type primitives:SelectableOptionGroup}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:SelectableOptionGroup}">
                    <Grid>
                        <Border Style="{TemplateBinding HighlightStyle}"
                                animations:FadeVisibilityAnimator.BindVisible="{Binding IsSelectionHighlightActive, RelativeSource={RelativeSource TemplatedParent}}"
                                animations:FadeVisibilityAnimator.Preset="Default"
                                animations:SelectionHighlightAnimation.IsEnabled="{Binding IsSelectionHighlightActive, RelativeSource={RelativeSource TemplatedParent}}"
                                animations:SelectionHighlightAnimation.Target="{Binding ElementName=PART_ContentHost}"
                                animations:SelectionHighlightAnimation.SelectedIndex="{Binding SelectedIndex, RelativeSource={RelativeSource TemplatedParent}}"/>
                        <ContentPresenter x:Name="PART_ContentHost"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SelectableOptionMenuGroup" TargetType="{x:Type primitives:SelectableOptionGroup}" BasedOn="{StaticResource SelectableOptionGroupBase}">
        <Setter Property="HighlightStyle" Value="{StaticResource SelectableOptionMenuHighlight}"/>
    </Style>

    <Style x:Key="SelectableOptionSegmentGroup" TargetType="{x:Type primitives:SelectableOptionGroup}" BasedOn="{StaticResource SelectableOptionGroupBase}">
        <Setter Property="HighlightStyle" Value="{StaticResource SelectableOptionSegmentHighlight}"/>
    </Style>

    <Style x:Key="AppPanelToolTip" TargetType="ToolTip" BasedOn="{StaticResource AppTooltipText}">
        <Setter Property="Background" Value="{StaticResource PopupMenuBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PopupPanelBorderBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Padding" Value="{StaticResource TooltipPanelPadding}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="AppPopupToolTip" TargetType="ToolTip" BasedOn="{StaticResource AppTooltipText}">
        <Setter Property="Placement" Value="Bottom"/>
        <Setter Property="HorizontalOffset" Value="0"/>
        <Setter Property="VerticalOffset" Value="{StaticResource OverlayVerticalOffsetDefault}"/>
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="AppInsetPanelBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceOverlayDark}"/>
        <Setter Property="CornerRadius" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource PopupPanelPadding}"/>
    </Style>

    <Style x:Key="AppSegmentedSurfaceBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LibraryFilterBarBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource LibraryFilterBarBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource LibraryFilterBarCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource LibraryFilterBarOuterPadding}"/>
    </Style>

    <Style x:Key="AppCardSurfaceBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SurfaceOverlayDark}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FolderCardCornerRadius}"/>
    </Style>

    <Style x:Key="LibraryCardSurfaceBorder" TargetType="Border" BasedOn="{StaticResource AppCardSurfaceBorder}">
        <Setter Property="Width" Value="{StaticResource FolderCardWidth}"/>
        <Setter Property="Height" Value="{StaticResource FolderCardHeight}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="animations:CardAnimation.Enabled" Value="True"/>
        <Setter Property="animations:CardAnimation.HoverDurationMs" Value="250"/>
        <Setter Property="animations:CardAnimation.PressDipMs" Value="100"/>
        <Setter Property="animations:CardAnimation.PressRecoverMs" Value="350"/>
        <Setter Property="animations:CardAnimation.CoverScale" Value="1.12"/>
        <Setter Property="animations:CardAnimation.CoverShiftY" Value="-8"/>
        <Setter Property="animations:CardAnimation.CoverDurationMs" Value="400"/>
        <Setter Property="behaviors:HoverRevealBehavior.IsEnabled" Value="True"/>
        <Setter Property="behaviors:HoverRevealBehavior.HideDelayMs" Value="120"/>
        <Setter Property="behaviors:HoverRevealBehavior.MinVisibleMs" Value="220"/>
    </Style>

    <Style x:Key="LibraryCardClipRootGrid" TargetType="Grid">
        <Setter Property="Clip">
            <Setter.Value>
                <RectangleGeometry RadiusX="{StaticResource LibraryCardClipRadius}"
                                   RadiusY="{StaticResource LibraryCardClipRadius}"
                                   Rect="{StaticResource LibraryCardClipRect}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LibraryCardPlaceholderIconText" TargetType="TextBlock" BasedOn="{StaticResource AppTextIconPlaceholder}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Text" Value="&#x1F3AC;"/>
    </Style>

    <Style x:Key="LibraryCardFavoriteHost" TargetType="Grid">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="{StaticResource LibraryCardFavoriteButtonMargin}"/>
        <Setter Property="Panel.ZIndex" Value="10"/>
        <Setter Property="Width" Value="{StaticResource LibraryCardFavoriteButtonSize}"/>
        <Setter Property="Height" Value="{StaticResource LibraryCardFavoriteButtonSize}"/>
        <Setter Property="animations:ScaleFadeVisibilityAnimator.IsEnabled" Value="True"/>
        <Setter Property="animations:ScaleFadeVisibilityAnimator.Preset" Value="Compact"/>
        <Setter Property="animations:ScaleFadeVisibilityAnimator.CollapseWhenInactive" Value="False"/>
    </Style>

    <Style x:Key="LibraryCardInfoOverlayBorder" TargetType="Border">
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Height" Value="{StaticResource FolderCardGradientHeight}"/>
        <Setter Property="Padding" Value="{StaticResource LibraryCardInfoPadding}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceOverlayDarkGradient}"/>
    </Style>

    <Style x:Key="LibraryCardInfoLayoutGrid" TargetType="Grid">
        <Setter Property="Margin" Value="{StaticResource CardInfoMargin}"/>
    </Style>

    <Style x:Key="LibraryCardSummaryRowPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="{StaticResource LibraryCardSummaryRowMargin}"/>
    </Style>

    <Style x:Key="LibraryCardProgressContainer" TargetType="Grid">
        <Setter Property="Margin" Value="{StaticResource LibraryCardProgressMargin}"/>
        <Setter Property="Height" Value="{StaticResource LibraryCardProgressContainerHeight}"/>
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
    </Style>

    <Style x:Key="LibraryCardProgressTrackBorder" TargetType="Border">
        <Setter Property="Height" Value="{StaticResource ProgressBarThinHeight}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource LibraryCardProgressTrack}"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProgressBarThinCornerRadius}"/>
    </Style>

    <Style x:Key="LibraryCardProgressFillBorder" TargetType="Border">
        <Setter Property="Height" Value="{StaticResource ProgressBarThinHeight}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProgressBarThinCornerRadius}"/>
    </Style>

    <Style x:Key="OverlayThinScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="{StaticResource ScrollbarThumbWidth}"/>
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource OverlayScrollbarThumbBackground}"
                                                    CornerRadius="{StaticResource ProgressBarThinCornerRadius}"
                                                    Width="{StaticResource ScrollbarThumbWidth}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlaylistEpisodeListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlaylistEpisodeItemMargin}"/>
        <Setter Property="Width" Value="{StaticResource EpisodeButtonSize}"/>
        <Setter Property="Height" Value="{StaticResource EpisodeButtonSize}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlaylistEpisodeListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlaylistItemsMargin}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource PlaylistEpisodeListBoxItem}"/>
    </Style>

    <Style x:Key="PlayerPlaylistPanelStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource PlaylistPanelWidth}"/>
        <Setter Property="Background" Value="{StaticResource PlayerPlaylistPanelBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PlayerPlaylistPanelBorder}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
    </Style>

    <Style x:Key="AppProgressBarThin" TargetType="ProgressBar">
        <Setter Property="Height" Value="{StaticResource ProgressBarThinHeight}"/>
        <Setter Property="Minimum" Value="0"/>
        <Setter Property="Maximum" Value="100"/>
        <Setter Property="Foreground" Value="{StaticResource ProgressFillPrimary}"/>
        <Setter Property="Background" Value="{StaticResource ProgressTrackBackground}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ProgressBarThinCornerRadius}">
                        <Grid x:Name="PART_Track"
                              ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource ProgressBarThinCornerRadius}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppProgressBarMedium" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarThin}">
        <Setter Property="Height" Value="{StaticResource ProgressBarMediumHeight}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ProgressBarMediumCornerRadius}">
                        <Grid x:Name="PART_Track"
                              ClipToBounds="True">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="{StaticResource ProgressBarMediumCornerRadius}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="AppProgressBarThinWarning" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarThin}">
        <Setter Property="Foreground" Value="{StaticResource ProgressFillWarning}"/>
    </Style>

    <Style x:Key="AppProgressBarThinSuccess" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarThin}">
        <Setter Property="Foreground" Value="{StaticResource ProgressFillSuccess}"/>
    </Style>

    <Style x:Key="AppProgressBarMediumWarning" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarMedium}">
        <Setter Property="Foreground" Value="{StaticResource ProgressFillWarning}"/>
    </Style>

    <Style x:Key="AppProgressBarMediumSuccess" TargetType="ProgressBar" BasedOn="{StaticResource AppProgressBarMedium}">
        <Setter Property="Foreground" Value="{StaticResource ProgressFillSuccess}"/>
    </Style>

    <Style TargetType="{x:Type overlays:AnimatedOverlay}">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type overlays:AnimatedOverlay}">
                    <Grid Background="{x:Null}"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Border x:Name="PART_PositionHost"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="{TemplateBinding SurfaceMargin}"
                                Background="{StaticResource TransparentBrush}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Border x:Name="PART_Surface"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="{StaticResource TransparentBrush}"
                                Opacity="0"
                                RenderTransformOrigin="{TemplateBinding AnimationOrigin}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <ContentPresenter shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                            </Border>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>

