<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App logo: play triangle -->
    <Geometry x:Key="AppIconGeometry">M1,0.5 L8.5,5 L1,9.5 Z</Geometry>

    <!-- Library favorite: five-point star -->
    <Geometry x:Key="FavoriteIconGeometry">M5,0.8 L6.45,3.75 L9.7,4.05 L7.25,6.2 L8.02,9.35 L5,7.75 L1.98,9.35 L2.75,6.2 L0.3,4.05 L3.55,3.75 Z</Geometry>

    <!-- Title bar window control icons -->
    <Geometry x:Key="MinimizeIconGeometry">M1,5 L9,5</Geometry>
    <RectangleGeometry x:Key="MaximizeIconGeometry" Rect="2,2,6,6" RadiusX="1" RadiusY="1"/>
    <GeometryGroup x:Key="RestoreIconGeometry">
        <RectangleGeometry Rect="4,2,4,4" RadiusX="1" RadiusY="1"/>
        <RectangleGeometry Rect="2,4,4,4" RadiusX="1" RadiusY="1"/>
    </GeometryGroup>
    <Geometry x:Key="CloseIconGeometry">M2,2 L8,8 M8,2 L2,8</Geometry>

    <!-- Submenu right arrow: equilateral triangle pointing right -->
    <Geometry x:Key="ChevronRightGeometry">M2,1 L8.5,5 L2,9 Z</Geometry>

</ResourceDictionary>
