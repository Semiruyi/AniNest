<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:animations="clr-namespace:AniNest.Presentation.Animations"
                    xmlns:behaviors="clr-namespace:AniNest.Presentation.Behaviors">

    <!-- Card shell -->
    <Style x:Key="LibraryCardSurfaceBorder" TargetType="Border" BasedOn="{StaticResource AppCardSurfaceBorder}">
        <Setter Property="Width" Value="{StaticResource FolderCardWidth}"/>
        <Setter Property="Height" Value="{StaticResource FolderCardHeight}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="animations:CardAnimation.Enabled" Value="True"/>
        <Setter Property="animations:CardAnimation.HoverDurationMs" Value="250"/>
        <Setter Property="animations:CardAnimation.PressDipMs" Value="100"/>
        <Setter Property="animations:CardAnimation.PressRecoverMs" Value="350"/>
        <Setter Property="animations:CardAnimation.CoverScale" Value="1.12"/>
        <Setter Property="animations:CardAnimation.CoverShiftY" Value="-8"/>
        <Setter Property="animations:CardAnimation.CoverDurationMs" Value="400"/>
        <Setter Property="behaviors:HoverRevealBehavior.IsEnabled" Value="True"/>
        <Setter Property="behaviors:HoverRevealBehavior.HideDelayMs" Value="120"/>
        <Setter Property="behaviors:HoverRevealBehavior.MinVisibleMs" Value="220"/>
    </Style>

    <!-- Card clipping and placeholder -->
    <Style x:Key="LibraryCardClipRootGrid" TargetType="Grid">
        <Setter Property="Clip">
            <Setter.Value>
                <RectangleGeometry RadiusX="{StaticResource LibraryCardClipRadius}"
                                   RadiusY="{StaticResource LibraryCardClipRadius}"
                                   Rect="{StaticResource LibraryCardClipRect}"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="LibraryCardPlaceholderIconText" TargetType="TextBlock" BasedOn="{StaticResource AppTextIconPlaceholder}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Text" Value="&#x1F3AC;"/>
    </Style>

    <!-- Card overlays -->
    <Style x:Key="LibraryCardFavoriteHost" TargetType="Grid">
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="{StaticResource LibraryCardFavoriteButtonMargin}"/>
        <Setter Property="Panel.ZIndex" Value="10"/>
        <Setter Property="Width" Value="{StaticResource LibraryCardFavoriteButtonSize}"/>
        <Setter Property="Height" Value="{StaticResource LibraryCardFavoriteButtonSize}"/>
        <Setter Property="animations:ScaleFadeVisibilityAnimator.IsEnabled" Value="True"/>
        <Setter Property="animations:ScaleFadeVisibilityAnimator.Preset" Value="Compact"/>
        <Setter Property="animations:ScaleFadeVisibilityAnimator.CollapseWhenInactive" Value="False"/>
    </Style>

    <Style x:Key="LibraryCardInfoOverlayBorder" TargetType="Border">
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Height" Value="{StaticResource FolderCardGradientHeight}"/>
        <Setter Property="Padding" Value="{StaticResource LibraryCardInfoPadding}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceOverlayDarkGradient}"/>
    </Style>

    <Style x:Key="LibraryCardInfoLayoutGrid" TargetType="Grid">
        <Setter Property="Margin" Value="{StaticResource CardInfoMargin}"/>
    </Style>

    <!-- Card summary and progress -->
    <Style x:Key="LibraryCardSummaryRowPanel" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="{StaticResource LibraryCardSummaryRowMargin}"/>
    </Style>

    <Style x:Key="LibraryCardProgressContainer" TargetType="Grid">
        <Setter Property="Margin" Value="{StaticResource LibraryCardProgressMargin}"/>
        <Setter Property="Height" Value="{StaticResource LibraryCardProgressContainerHeight}"/>
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
    </Style>

    <Style x:Key="LibraryCardProgressTrackBorder" TargetType="Border">
        <Setter Property="Height" Value="{StaticResource ProgressBarThinHeight}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource LibraryCardProgressTrack}"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProgressBarThinCornerRadius}"/>
    </Style>

    <Style x:Key="LibraryCardProgressFillBorder" TargetType="Border">
        <Setter Property="Height" Value="{StaticResource ProgressBarThinHeight}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
        <Setter Property="CornerRadius" Value="{StaticResource ProgressBarThinCornerRadius}"/>
    </Style>

</ResourceDictionary>
