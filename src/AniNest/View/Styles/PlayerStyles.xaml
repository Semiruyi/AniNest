<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:AniNest.Presentation.Converters"
                    xmlns:local="clr-namespace:AniNest.Features.Player"
                    xmlns:primitives="clr-namespace:AniNest.Presentation.Primitives"
                    xmlns:overlays="clr-namespace:AniNest.Presentation.Overlays">

    <converters:RateToOffsetConverter x:Key="RateToOffsetConverter"/>

    <ItemsPanelTemplate x:Key="PlaylistEpisodeItemsPanelTemplate">
        <primitives:AnimatedWrapPanel Orientation="Horizontal"
                                      AnimationDuration="0:0:0.2"/>
    </ItemsPanelTemplate>

    <Style x:Key="OverlayThinScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="{StaticResource ScrollbarThumbWidth}"/>
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource OverlayScrollbarThumbBackground}"
                                                    CornerRadius="{StaticResource ProgressBarThinCornerRadius}"
                                                    Width="{StaticResource ScrollbarThumbWidth}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlaylistEpisodeListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlaylistEpisodeItemMargin}"/>
        <Setter Property="Width" Value="{StaticResource EpisodeButtonSize}"/>
        <Setter Property="Height" Value="{StaticResource EpisodeButtonSize}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlaylistEpisodeListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlaylistItemsMargin}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource PlaylistEpisodeListBoxItem}"/>
    </Style>

    <Style x:Key="PlayerPlaylistPanelStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource PlaylistPanelWidth}"/>
        <Setter Property="Background" Value="{StaticResource PlayerPlaylistPanelBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PlayerPlaylistPanelBorder}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
    </Style>

    <Style x:Key="PlayerControlBarTimeText" TargetType="TextBlock" BasedOn="{StaticResource AppTextCaption}">
        <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PlayerControlBarTimeSeparatorText" TargetType="TextBlock" BasedOn="{StaticResource PlayerControlBarTimeText}">
        <Setter Property="Foreground" Value="{StaticResource ControlBarTimeSeparatorForeground}"/>
        <Setter Property="Margin" Value="{StaticResource TimeSeparatorMargin}"/>
    </Style>

    <Style x:Key="PlayerControlBarIconImageSmall" TargetType="Image">
        <Setter Property="Width" Value="{StaticResource IconSizeSmall}"/>
        <Setter Property="Height" Value="{StaticResource IconSizeSmall}"/>
    </Style>

    <Style x:Key="PlayerControlBarIconImageNormal" TargetType="Image">
        <Setter Property="Width" Value="{StaticResource IconSizeNormal}"/>
        <Setter Property="Height" Value="{StaticResource IconSizeNormal}"/>
    </Style>

    <Style x:Key="PlayerControlBarIconImageLarge" TargetType="Image">
        <Setter Property="Width" Value="{StaticResource IconSizeLarge}"/>
        <Setter Property="Height" Value="{StaticResource IconSizeLarge}"/>
    </Style>

    <Style x:Key="PlayerThumbnailPreviewTimeBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ThumbnailPreviewTimeBackground}"/>
        <Setter Property="CornerRadius" Value="{StaticResource ThumbnailPreviewTimeCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource ThumbnailPreviewTimePadding}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
    </Style>

    <Style x:Key="PlayerThumbnailPreviewTimeText" TargetType="TextBlock" BasedOn="{StaticResource AppTextThumbnailPreview}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <Style x:Key="PlayerSpeedOverlay"
           TargetType="{x:Type overlays:AnimatedOverlay}"
           BasedOn="{StaticResource {x:Type overlays:AnimatedOverlay}}">
        <Setter Property="InteractionPreset" Value="ToolPanelLike"/>
        <Setter Property="Placement" Value="TopCenter"/>
        <Setter Property="ConstrainToHostBounds" Value="False"/>
        <Setter Property="VerticalOffset" Value="{StaticResource OverlayVerticalOffsetProminent}"/>
        <Setter Property="AnimationOrigin" Value="0.5,1"/>
    </Style>

    <Style x:Key="PlayerSpeedOverlayHighlight" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource PopupMenuButtonCornerRadius}"/>
        <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
        <Setter Property="Height" Value="{StaticResource SpeedOptionHeight}"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <Style x:Key="PlayerSpeedOptionText" TargetType="TextBlock" BasedOn="{StaticResource AppTextBody}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PlayerPlaylistHeaderText" TargetType="TextBlock" BasedOn="{StaticResource AppTextPanelTitle}">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PlayerPlaylistMetaText" TargetType="TextBlock" BasedOn="{StaticResource AppTextBody}">
        <Setter Property="Foreground" Value="{StaticResource PlayerPlaylistMetaForeground}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style x:Key="PlayerEpisodeToolTipText" TargetType="TextBlock" BasedOn="{StaticResource AppTextBody}">
        <Setter Property="MaxWidth" Value="{StaticResource PlayerEpisodeToolTipMaxWidth}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>

    <Style x:Key="PlayerEpisodeToolTip" TargetType="ToolTip" BasedOn="{StaticResource AppPanelToolTip}"/>

    <Style x:Key="PlayerEpisodeNumberText" TargetType="TextBlock" BasedOn="{StaticResource AppTextPanelValue}">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="PlayerPauseBigIconImage" TargetType="Image">
        <Setter Property="Width" Value="{StaticResource PauseBigIconSize}"/>
        <Setter Property="Height" Value="{StaticResource PauseBigIconSize}"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Bottom"/>
        <Setter Property="Margin" Value="{StaticResource PauseBigIconMargin}"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
    </Style>

    <Style x:Key="PlayerControlBarViewStyle" TargetType="{x:Type local:ControlBarView}">
        <Setter Property="Grid.Row" Value="1"/>
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="IsHitTestVisible" Value="True"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                <Setter Property="Grid.Row" Value="0"/>
                <Setter Property="VerticalAlignment" Value="Bottom"/>
                <Setter Property="Panel.ZIndex" Value="1"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsControlBarVisible}" Value="False">
                <Setter Property="IsHitTestVisible" Value="False"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.12"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
