<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="OverlayThinScrollBar" TargetType="ScrollBar">
        <Setter Property="Width" Value="{StaticResource ScrollbarThumbWidth}"/>
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{StaticResource OverlayScrollbarThumbBackground}"
                                                    CornerRadius="{StaticResource ProgressBarThinCornerRadius}"
                                                    Width="{StaticResource ScrollbarThumbWidth}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlaylistEpisodeListBoxItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlaylistEpisodeItemMargin}"/>
        <Setter Property="Width" Value="{StaticResource EpisodeButtonSize}"/>
        <Setter Property="Height" Value="{StaticResource EpisodeButtonSize}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PlaylistEpisodeListBox" TargetType="ListBox">
        <Setter Property="Background" Value="{StaticResource TransparentBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="{StaticResource PlaylistItemsMargin}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource PlaylistEpisodeListBoxItem}"/>
    </Style>

    <Style x:Key="PlayerPlaylistPanelStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource PlaylistPanelWidth}"/>
        <Setter Property="Background" Value="{StaticResource PlayerPlaylistPanelBackground}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PlayerPlaylistPanelBorder}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
    </Style>

</ResourceDictionary>
