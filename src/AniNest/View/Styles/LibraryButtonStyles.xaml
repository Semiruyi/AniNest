<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:persistence="clr-namespace:AniNest.Infrastructure.Persistence;assembly=AniNest.Ports">

    <!-- Card action buttons -->
    <Style x:Key="LibraryCardFavoriteButton" TargetType="Button" BasedOn="{StaticResource AnimatedCompactIconButton}">
        <Setter Property="Width" Value="{StaticResource LibraryCardFavoriteButtonSize}"/>
        <Setter Property="Height" Value="{StaticResource LibraryCardFavoriteButtonSize}"/>
        <Setter Property="Opacity" Value="0.84"/>
        <Setter Property="Background" Value="{StaticResource SurfaceOverlayDark}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="ButtonRoot"
                          Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Ellipse Fill="{TemplateBinding Background}"
                                 Opacity="0.9"/>
                        <Ellipse x:Name="HoverBg"
                                 Fill="{DynamicResource HoverBackground}"
                                 Opacity="0"/>
                        <Grid Width="{StaticResource LibraryCardFavoriteIconSize}"
                              Height="{StaticResource LibraryCardFavoriteIconSize}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="FavoriteIconScale" ScaleX="1" ScaleY="1"/>
                            </Grid.RenderTransform>
                            <Path x:Name="FavoriteFillIcon"
                                  Data="{StaticResource FavoriteIconGeometry}"
                                  Stretch="Uniform"
                                  Opacity="0">
                                <Path.Fill>
                                    <StaticResource ResourceKey="LibraryFavoriteColor"/>
                                </Path.Fill>
                            </Path>
                            <Path x:Name="FavoriteStrokeIcon"
                                  Data="{StaticResource FavoriteIconGeometry}"
                                  Stretch="Uniform"
                                  StrokeThickness="1.3"
                                  Fill="{StaticResource TransparentBrush}">
                                <Path.Stroke>
                                    <StaticResource ResourceKey="LibraryFavoriteStrokeColor"/>
                                </Path.Stroke>
                            </Path>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                            <Setter Property="Opacity" Value="0.92"/>
                            <Setter TargetName="FavoriteFillIcon" Property="Opacity" Value="1"/>
                            <Setter TargetName="FavoriteStrokeIcon" Property="Stroke" Value="{StaticResource LibraryFavoriteColor}"/>
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="FavoriteStrokeIcon"
                                                        Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                        To="{StaticResource LibraryFavoriteColorValue}"
                                                        Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="FavoriteFillIcon"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.16"/>
                                        <DoubleAnimation Storyboard.TargetName="FavoriteIconScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         From="0.86"
                                                         To="1"
                                                         Duration="0:0:0.20"/>
                                        <DoubleAnimation Storyboard.TargetName="FavoriteIconScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         From="0.86"
                                                         To="1"
                                                         Duration="0:0:0.20"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="FavoriteStrokeIcon"
                                                        Storyboard.TargetProperty="(Shape.Stroke).(SolidColorBrush.Color)"
                                                        To="{StaticResource LibraryFavoriteStrokeColorValue}"
                                                        Duration="0:0:0.16"/>
                                        <DoubleAnimation Storyboard.TargetName="FavoriteFillIcon"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.14"/>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FavoriteIconScale"
                                                                       Storyboard.TargetProperty="ScaleX">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.88"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="FavoriteIconScale"
                                                                       Storyboard.TargetProperty="ScaleY">
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.88"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.16" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Card status buttons -->
    <Style x:Key="LibraryCardStatusButton" TargetType="Button" BasedOn="{StaticResource MenuButtonBase}">
        <Setter Property="Height" Value="{StaticResource LibraryCardStatusButtonHeight}"/>
        <Setter Property="MinWidth" Value="{StaticResource LibraryCardStatusButtonMinWidth}"/>
        <Setter Property="Padding" Value="{StaticResource LibraryCardStatusButtonPadding}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="{StaticResource AppFontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="Background" Value="{StaticResource LibraryStatusUnsortedBackground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="BgBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource LibraryCardStatusButtonCornerRadius}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Border x:Name="HoverBg"
                                    Background="{StaticResource PressedBackground}"
                                    CornerRadius="{StaticResource LibraryCardStatusButtonCornerRadius}"
                                    Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static persistence:WatchStatus.Watching}">
                <Setter Property="Background" Value="{StaticResource LibraryStatusWatchingBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static persistence:WatchStatus.Unsorted}">
                <Setter Property="Background" Value="{StaticResource LibraryStatusUnsortedBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static persistence:WatchStatus.Completed}">
                <Setter Property="Background" Value="{StaticResource LibraryStatusCompletedBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Status}" Value="{x:Static persistence:WatchStatus.Dropped}">
                <Setter Property="Background" Value="{StaticResource LibraryStatusDroppedBackground}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="LibraryCardStatusValueText" TargetType="TextBlock" BasedOn="{StaticResource LibraryCardStatusText}"/>

</ResourceDictionary>
