<UserControl x:Class="AniNest.View.MainWindowTitleBar"
             x:Name="RootControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:animations="clr-namespace:AniNest.Presentation.Animations"
             xmlns:converters="clr-namespace:AniNest.Presentation.Converters"
             xmlns:primitives="clr-namespace:AniNest.Presentation.Primitives"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework">
    <UserControl.Resources>
        <converters:ProgressToRingArcConverter x:Key="ProgressToRingArcConverter"/>
    </UserControl.Resources>
    <Border x:Name="TitleBarRoot"
            Background="{StaticResource BackgroundDark}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="{StaticResource TitleBarLeftMargin}">
                <Image Source="/Resources/Icons/App.png"
                       Width="{StaticResource TitleBarAppIconSize}"
                       Height="{StaticResource TitleBarAppIconSize}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       SnapsToDevicePixels="True"/>
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOnMainPage}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Button x:Name="FileButton"
                            Style="{StaticResource TitleBarTextButton}"
                            Content="{Binding DataContext.Localization[App.File], RelativeSource={RelativeSource AncestorType=Window}}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOnPlayerPage}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Button x:Name="BackButton"
                            Style="{StaticResource TitleBarTextButton}"
                            Command="{Binding GoBackFromPlayerTitleBarCommand}"
                            Content="{Binding DataContext.Localization[KeyBinding.Back], RelativeSource={RelativeSource AncestorType=Window}}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
                <Grid>
                    <Button x:Name="SettingsButton"
                            Style="{StaticResource TitleBarTextButton}"
                            Content="{Binding DataContext.Localization[App.Settings], RelativeSource={RelativeSource AncestorType=Window}}"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                </Grid>
            </StackPanel>

            <Grid x:Name="TitleBarDragZone"
                  Grid.Column="1">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Margin="0,0,46,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Border x:Name="BackgroundTaskHost"
                            Margin="0,0,10,0"
                            Padding="10,5"
                            Background="Transparent"
                            BorderThickness="0"
                            MouseEnter="BackgroundTaskHost_MouseEnter"
                            MouseLeave="BackgroundTaskHost_MouseLeave"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid>
                            <Viewbox Width="16"
                                     Height="16"
                                     Stretch="Uniform"
                                     VerticalAlignment="Center">
                                <Grid Width="20"
                                      Height="20">
                                    <Ellipse Stroke="#33FFFFFF"
                                             StrokeThickness="3"/>
                                    <Path Data="{Binding ThumbnailGenerationProgressPercent, Converter={StaticResource ProgressToRingArcConverter}}"
                                          Stroke="{Binding ThumbnailGenerationStatusColor}"
                                          StrokeThickness="3"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </Grid>
                            </Viewbox>
                        </Grid>
                    </Border>
                    <primitives:AnimatedPopup PlacementTarget="{Binding ElementName=BackgroundTaskHost}"
                                              Placement="Center"
                                              AllowsTransparency="True"
                                              IsHitTestVisible="True"
                                              StaysOpen="True"
                                              IsOpenAnimated="{Binding ElementName=RootControl, Path=IsBackgroundTaskPopupOpen}"
                                              OpenAnimationOrigin="0.5,0"
                                              HorizontalOffset="0"
                                              VerticalOffset="114">
                        <Border x:Name="BackgroundTaskPopupContent"
                                Background="{StaticResource PopupMenuBackground}"
                                BorderBrush="#38383A"
                                BorderThickness="1"
                                CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                                Padding="12,10"
                                MaxWidth="320"
                                MouseEnter="BackgroundTaskPopupContent_MouseEnter"
                                MouseLeave="BackgroundTaskPopupContent_MouseLeave">
                            <StackPanel>
                                <TextBlock Text="{Binding DataContext.Localization[TitleBar.ThumbnailBackgroundTask], RelativeSource={RelativeSource AncestorType=Window}}"
                                           Style="{StaticResource AppTextPanelTitle}"
                                           Foreground="{StaticResource TextPrimary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Ellipse Width="8"
                                             Height="8"
                                             VerticalAlignment="Center"
                                             Fill="{Binding ThumbnailGenerationStatusColor}"/>
                                    <TextBlock Grid.Column="1"
                                               Style="{StaticResource AppTextBodyEmphasis}"
                                               Text="{Binding ThumbnailGenerationStatusText}"
                                               Margin="8,0,0,0"
                                               Foreground="{StaticResource TextPrimary}"/>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource AppTextBody}"
                                               Text="{Binding ThumbnailGenerationCountText}"
                                               Foreground="{StaticResource TextSecondary}"/>
                                </Grid>
                                <ProgressBar Height="4"
                                             Minimum="0"
                                             Maximum="100"
                                             Value="{Binding ThumbnailGenerationProgressPercent}"
                                             Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding ThumbnailGenerationDetailText}"
                                           Style="{StaticResource OverlaySecondaryText}"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding ThumbnailGenerationTooltipText}"
                                           Style="{StaticResource AppTextBody}"
                                           Foreground="{StaticResource TextSecondary}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </primitives:AnimatedPopup>
                    <Grid x:Name="TitleBarFileNameHost"
                          VerticalAlignment="Center"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Setter Property="animations:FadeVisibilityAnimator.BindVisible" Value="{Binding IsOnPlayerPage}"/>
                                <Setter Property="animations:FadeVisibilityAnimator.DurationMs" Value="420"/>
                            </Style>
                        </Grid.Style>
                        <Grid.ToolTip>
                            <ToolTip Style="{StaticResource AppTooltipText}"
                                     Placement="Bottom"
                                     HorizontalOffset="0"
                                     VerticalOffset="8"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0">
                                <Border Background="{StaticResource PopupMenuBackground}"
                                        BorderBrush="#38383A"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                                        Padding="10,8"
                                        MaxWidth="560">
                                    <TextBlock Text="{Binding CurrentPlayerTitleBarToolTip}"
                                               Style="{StaticResource AppTextBody}"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </ToolTip>
                        </Grid.ToolTip>
                        <Grid animations:FadeTextSwapAnimator.Text="{Binding CurrentPlayerTitleBarText}"
                              animations:FadeTextSwapAnimator.DurationMs="420">
                            <TextBlock Text=""
                                       Style="{StaticResource AppTextTitleBar}"
                                       Foreground="{StaticResource TextSecondary}"
                                       Opacity="0"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text=""
                                       Style="{StaticResource AppTextTitleBar}"
                                       Foreground="{StaticResource TextSecondary}"
                                       Opacity="{StaticResource TitleBarTextOpacity}"
                                       TextTrimming="CharacterEllipsis"/>
                        </Grid>
                    </Grid>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button x:Name="MinimizeButton"
                        Style="{StaticResource TitleBarIconButton}"
                        Width="{StaticResource TitleBarButtonWidth}"
                        Height="{StaticResource TitleBarButtonHeight}"
                        ToolTip="{Binding DataContext.Localization[Window.Minimize], RelativeSource={RelativeSource AncestorType=Window}}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Viewbox Width="{StaticResource TitleBarIconSize}"
                             Height="{StaticResource TitleBarIconSize}">
                        <Path Data="{StaticResource MinimizeIconGeometry}"
                              Stroke="White"
                              StrokeThickness="{StaticResource TitleBarIconStroke}"
                              StrokeEndLineCap="Round"/>
                    </Viewbox>
                </Button>

                <Button x:Name="MaximizeButton"
                        Width="{StaticResource TitleBarButtonWidth}"
                        Height="{StaticResource TitleBarButtonHeight}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Viewbox Width="{StaticResource TitleBarIconSize}"
                             Height="{StaticResource TitleBarIconSize}">
                        <Path Stroke="White"
                              StrokeThickness="{StaticResource TitleBarIconStroke}"
                              StrokeLineJoin="Round">
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="Data"
                                            Value="{StaticResource MaximizeIconGeometry}"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="Maximized"
                                                     Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Setter Property="Data"
                                                    Value="{StaticResource RestoreIconGeometry}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Path.Style>
                        </Path>
                    </Viewbox>
                    <Button.Style>
                        <Style TargetType="Button"
                               BasedOn="{StaticResource TitleBarIconButton}">
                            <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Window.Maximize], RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Style.Triggers>
                                <DataTrigger Value="Maximized"
                                             Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Window.Restore], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="CloseButton"
                        Style="{StaticResource CloseIconButton}"
                        Width="{StaticResource TitleBarButtonWidth}"
                        Height="{StaticResource TitleBarButtonHeight}"
                        ToolTip="{Binding DataContext.Localization[Window.Close], RelativeSource={RelativeSource AncestorType=Window}}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Viewbox Width="{StaticResource TitleBarIconSize}"
                             Height="{StaticResource TitleBarIconSize}">
                        <Path Data="{StaticResource CloseIconGeometry}"
                              Stroke="White"
                              StrokeThickness="{StaticResource TitleBarIconStroke}"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"/>
                    </Viewbox>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
