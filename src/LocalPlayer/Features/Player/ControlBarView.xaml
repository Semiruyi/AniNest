<UserControl x:Class="LocalPlayer.Features.Player.ControlBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LocalPlayer.Presentation.Converters"
             xmlns:animations="clr-namespace:LocalPlayer.Presentation.Animations"
             xmlns:behaviors="clr-namespace:LocalPlayer.Presentation.Behaviors"
             xmlns:primitives="clr-namespace:LocalPlayer.Presentation.Primitives"
             xmlns:loc="clr-namespace:LocalPlayer.Core.Localization"
             Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:RateToOffsetConverter x:Key="RateToOffsetConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Height="{StaticResource ControlBarHeight}"
          Focusable="True"
          behaviors:KeyboardBehavior.KeyDownCommand="{Binding KeyDownCommand}">
        <Grid.Background>
            <SolidColorBrush Color="#CC0F0F0F"/>
        </Grid.Background>

        <Grid Margin="{StaticResource ControlBarHorizontalMargin}"
              VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 宸︿晶锛氭挱鏀炬帶鍒?+ 鏃堕棿 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <Button x:Name="PreviousBtn" Style="{StaticResource IconButton}"
                        Command="{Binding PreviousCommand}" ToolTip="{Binding PreviousTooltip}"
                        Focusable="False"
                        Margin="{StaticResource ButtonGapRight}"
                        animations:ButtonScaleHover.IsEnabled="True">
                    <Image Source="/Resources/Icons/previous.png"
                           Width="{StaticResource IconSizeSmall}"
                           Height="{StaticResource IconSizeSmall}"/>
                </Button>
                <Button x:Name="PlayPauseBtn" Style="{StaticResource IconButton}"
                        Width="{StaticResource PlayPauseButtonSize}"
                        Height="{StaticResource PlayPauseButtonSize}"
                        Opacity="0.85" Command="{Binding PlayPauseCommand}"
                        Margin="{StaticResource ButtonGapBoth}"
                        ToolTip="{Binding PlayPauseTooltip}" Focusable="False"
                        animations:ButtonScaleHover.IsEnabled="True">
                    <Grid animations:IconCrossfader.IsActive="{Binding IsPlaying}"
                          animations:IconCrossfader.DurationMs="300"
                          animations:IconCrossfader.ListenButton="{Binding ElementName=PlayPauseBtn}">
                        <Image Source="/Resources/Icons/play.png"
                               Width="{StaticResource IconSizeLarge}"
                               Height="{StaticResource IconSizeLarge}"
                               Opacity="1"/>
                        <Image Source="/Resources/Icons/pause.png"
                               Width="{StaticResource IconSizeLarge}"
                               Height="{StaticResource IconSizeLarge}"
                               Opacity="0"/>
                    </Grid>
                </Button>
                <Button x:Name="NextBtn" Style="{StaticResource IconButton}"
                        Command="{Binding NextCommand}" ToolTip="{Binding NextTooltip}"
                        Focusable="False"
                        Margin="{StaticResource ButtonGapRight}"
                        animations:ButtonScaleHover.IsEnabled="True">
                    <Image Source="/Resources/Icons/next.png"
                           Width="{StaticResource IconSizeSmall}"
                           Height="{StaticResource IconSizeSmall}"/>
                </Button>
                <Button x:Name="StopBtn" Style="{StaticResource IconButton}"
                        Command="{Binding StopCommand}"
                        Margin="{StaticResource ButtonGapLeft}" ToolTip="{Binding [Player.Stop], Source={x:Static loc:LocalizationService.Instance}}"
                        Focusable="False">
                    <Image Source="/Resources/Icons/stop.png"
                           Width="{StaticResource IconSizeSmall}"
                           Height="{StaticResource IconSizeSmall}"/>
                </Button>
                <TextBlock Text="{Binding CurrentTimeText, FallbackValue='00:00'}"
                           Foreground="{StaticResource TextSecondary}" FontSize="11"
                           VerticalAlignment="Center"
                           Margin="{StaticResource TimeTextLeftMargin}"
                           FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                <TextBlock Text=" / " Foreground="#66FFFFFF" FontSize="11"
                           VerticalAlignment="Center"
                           Margin="{StaticResource TimeSeparatorMargin}"/>
                <TextBlock Text="{Binding TotalTimeText, FallbackValue='00:00'}"
                           Foreground="{StaticResource TextSecondary}" FontSize="11"
                           VerticalAlignment="Center"
                           FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
            </StackPanel>

            <!-- 涓棿锛氳繘搴︽潯 -->
            <primitives:SeekBar x:Name="SeekBar" Grid.Column="1"
                                Position="{Binding CurrentTime, Mode=TwoWay}"
                                Duration="{Binding TotalTime}"
                                BufferedPosition="{Binding BufferedPosition}"
                                IsSeeking="{Binding IsSeeking, Mode=TwoWay}"
                                SeekCommand="{Binding SeekCommand}"
                                ThumbnailPreview="{Binding ThumbnailPreview}"
                                VerticalAlignment="Center"
                                ShowTooltip="False"
                                Margin="{StaticResource ControlBarSliderMargin}"/>

            <primitives:AnimatedPopup PlacementTarget="{Binding ElementName=SeekBar}"
                   Placement="Relative"
                   AllowsTransparency="True"
                   IsHitTestVisible="False"
                   StaysOpen="True"
                   IsOpenAnimated="{Binding ThumbnailPreview.IsOpen}"
                   OpenAnimationOrigin="0.5,1"
                   HorizontalOffset="{Binding ThumbnailPreview.HOffset}"
                   VerticalOffset="{StaticResource ThumbnailPopupOffset}">
                <Border Background="{StaticResource PopupMenuBackground}"
                        CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                        Padding="{StaticResource PopupMenuPadding}">
                    <Grid>
                        <Border x:Name="ThumbnailImageBorder"
                                Width="{StaticResource ThumbnailPopupWidth}"
                                Height="{StaticResource ThumbnailPopupHeight}">
                            <Border.Clip>
                                <RectangleGeometry RadiusX="{StaticResource ThumbnailPreviewImageClipRadius}"
                                                   RadiusY="{StaticResource ThumbnailPreviewImageClipRadius}"
                                                   Rect="0,0,160,90"/>
                            </Border.Clip>
                            <Image Source="{Binding ThumbnailPreview.ImageSource}"
                                   Visibility="{Binding ThumbnailPreview.ImageVisibility}"
                                   Width="{StaticResource ThumbnailPopupWidth}"
                                   Height="{StaticResource ThumbnailPopupHeight}"
                                   Stretch="UniformToFill"/>
                        </Border>
                        <Border Background="{StaticResource ThumbnailPreviewTimeBackground}"
                                CornerRadius="{StaticResource ThumbnailPreviewTimeCornerRadius}"
                                Padding="{StaticResource ThumbnailPreviewTimePadding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding ThumbnailPreview.TimeText}"
                                       Foreground="{StaticResource TextPrimary}"
                                       FontSize="{StaticResource ThumbnailPreviewFontSize}"
                                       FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                        </Border>
                    </Grid>
                </Border>
            </primitives:AnimatedPopup>

            <!-- 鍙充晶锛氬€嶉€?+ 鑿滃崟 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <!-- 鍊嶉€熸寜閽?-->
                <Grid>
                    <Button x:Name="SpeedBtn"
                            Style="{StaticResource IconButton}"
                            FontSize="11" FontWeight="SemiBold"
                            Foreground="White" Focusable="False"
                            Margin="{StaticResource ButtonGapRight}"
                            Command="{Binding ToggleSpeedPopupCommand}"
                            animations:ButtonScaleHover.IsEnabled="True">
                        <Grid animations:TextSwapAnimator.Text="{Binding Rate, StringFormat={}{0:0.0#}x}">
                            <TextBlock Text="" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="0" RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                            <TextBlock Text="" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Opacity="1" RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Grid>
                    </Button>
                    <primitives:AnimatedPopup x:Name="SpeedPopup"
                           StaysOpen="True"
                           IsOpenAnimated="{Binding IsSpeedPopupOpen}"
                           OpenAnimationOrigin="0.5,1"
                           OutsideClickPassthroughTargets="ControlBarGesture"
                           PlacementTarget="{Binding ElementName=SpeedBtn}"
                           Placement="Center"
                           VerticalOffset="{StaticResource SpeedPopupOffset}"
                           AllowsTransparency="True">
                        <Border Background="{StaticResource PopupMenuBackground}"
                                CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                                Padding="{StaticResource PopupMenuPadding}"
                                MinWidth="{StaticResource SpeedPopupMinWidth}">
                            <Grid>
                                <Border CornerRadius="{StaticResource PopupMenuButtonCornerRadius}"
                                        Background="{StaticResource AccentBlue}"
                                        Height="{StaticResource SpeedOptionHeight}"
                                        VerticalAlignment="Top"
                                        animations:SlideAnimator.TargetY="{Binding Rate, Converter={StaticResource RateToOffsetConverter}}">
                                    <Border.RenderTransform>
                                        <TranslateTransform Y="0"/>
                                    </Border.RenderTransform>
                                </Border>
                                <ItemsControl ItemsSource="{Binding SpeedOptions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource PopupMenuButton}"
                                                    HorizontalContentAlignment="Center"
                                                    Command="{Binding DataContext.ChangeSpeedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <TextBlock Text="{Binding StringFormat={}{0:0.0#}x}"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </primitives:AnimatedPopup>
                </Grid>

                <Button x:Name="PlaylistToggleBtn" Style="{StaticResource IconButton}"
                        Command="{Binding TogglePlaylistCommand}"
                        Margin="{StaticResource ButtonGapLeft}" ToolTip="{Binding [Player.Playlist], Source={x:Static loc:LocalizationService.Instance}}"
                        Focusable="False">
                    <Image Source="/Resources/Icons/playlist.png"
                           Width="{StaticResource IconSizeNormal}"
                           Height="{StaticResource IconSizeNormal}"/>
                </Button>
                <Button x:Name="FullscreenBtn"
                        Margin="{StaticResource ButtonGapLeft}" Focusable="False"
                        Command="{Binding ToggleFullscreenCommand}"
                        animations:ButtonScaleHover.IsEnabled="True">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                            <Setter Property="ToolTip" Value="{Binding [Player.Fullscreen], Source={x:Static loc:LocalizationService.Instance}}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                                    <Setter Property="ToolTip" Value="{Binding [Player.ExitFullscreen], Source={x:Static loc:LocalizationService.Instance}}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <Image Width="{StaticResource IconSizeNormal}"
                           Height="{StaticResource IconSizeNormal}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" Value="/Resources/Icons/fullScreen.png"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsFullscreen}" Value="True">
                                        <Setter Property="Source" Value="/Resources/Icons/exitFullScreen.png"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>



