<Window x:Class="LocalPlayer.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:LocalPlayer.Presentation.Primitives"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:featuresLibrary="clr-namespace:LocalPlayer.Features.Library"
        xmlns:featuresPlayer="clr-namespace:LocalPlayer.Features.Player"
        xmlns:playerSettings="clr-namespace:LocalPlayer.Features.Player.Settings"
        xmlns:pagesLibrary="clr-namespace:LocalPlayer.Features.Library"
        xmlns:pagesPlayer="clr-namespace:LocalPlayer.Features.Player"
        xmlns:animations="clr-namespace:LocalPlayer.Presentation.Animations"
        Title="LocalPlayer"
        Height="{StaticResource WindowDefaultHeight}"
        Width="{StaticResource WindowDefaultWidth}"
        MinWidth="{StaticResource WindowMinWidth}"
        MinHeight="{StaticResource WindowMinHeight}"
        Background="Transparent"
        InputMethod.IsInputMethodEnabled="False"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <CubicEase x:Key="SubmenuSlideEase" EasingMode="EaseInOut"/>

        <DataTemplate DataType="{x:Type featuresLibrary:MainPageViewModel}">
            <pagesLibrary:MainPage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type featuresPlayer:PlayerViewModel}">
            <pagesPlayer:PlayerPage/>
        </DataTemplate>

        <Storyboard x:Key="SlideToFirst">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             To="0" Duration="0:0:0.3"
                             EasingFunction="{StaticResource SubmenuSlideEase}"/>
        </Storyboard>
        <Storyboard x:Key="SlideToSecond">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             To="34" Duration="0:0:0.3"
                             EasingFunction="{StaticResource SubmenuSlideEase}"/>
        </Storyboard>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{StaticResource TitleBarHeight}"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border ClipToBounds="True"
            Background="{StaticResource BackgroundDark}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="{StaticResource WindowCornerRadius}"/>
                <Style.Triggers>
                    <DataTrigger Value="Maximized"
                        Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Setter Property="CornerRadius" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TitleBarRow" Height="{StaticResource TitleBarRowHeight}"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBarRoot" Grid.Row="0" Background="{StaticResource BackgroundDark}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="{StaticResource TitleBarLeftMargin}">
                        <Viewbox Width="{StaticResource TitleBarAppIconSize}"
                                 Height="{StaticResource TitleBarAppIconSize}"
                                 VerticalAlignment="Center">
                            <Path Data="{StaticResource AppIconGeometry}"
                                  Fill="{StaticResource AccentBlue}"/>
                        </Viewbox>
                        <Grid animations:VisibilityAnimator.BindVisible="{Binding IsOnMainPage}">
                            <Button x:Name="FileButton"
                                    Style="{StaticResource TitleBarTextButton}"
                                    Content="{Binding DataContext.Localization[App.File], RelativeSource={RelativeSource AncestorType=Window}}"
                                    Command="{Binding OpenFilePopupCommand}"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                            <primitives:AnimatedPopup x:Name="FilePopup"
                                   StaysOpen="True"
                                   IsOpenAnimated="{Binding IsFilePopupOpen}"
                                   OpenAnimationOrigin="0,0"
                                   PlacementTarget="{Binding ElementName=FileButton}"
                                   Placement="Bottom"
                                   HorizontalOffset="{StaticResource PopupMenuHorizontalOffset}"
                                   AllowsTransparency="True">
                                <Border Background="{StaticResource PopupMenuBackground}"
                                        CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                                        Padding="{StaticResource PopupMenuPadding}"
                                        MinWidth="{StaticResource PopupFileMenuMinWidth}">
                                    <StackPanel>
                                        <Button Style="{StaticResource PopupMenuButton}"
                                                Command="{Binding AddFolderCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6H12L10 4Z"
                                                      Fill="{StaticResource IconSecondary}"
                                                      Width="{StaticResource IconSizeNormal}"
                                                      Height="{StaticResource IconSizeNormal}"
                                                      Stretch="Uniform"
                                                      Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding DataContext.Localization[App.AddFolder], RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource PopupMenuButton}"
                                                Command="{Binding AddFolderBatchCommand}">
                                            <StackPanel Orientation="Horizontal">
                                                <Path Data="M10 4H4C2.9 4 2 4.9 2 6V18C2 19.1 2.9 20 4 20H20C21.1 20 22 19.1 22 18V8C22 6.9 21.1 6 20 6H12L10 4Z M17 13H13V17H11V13H7V11H11V7H13V11H17V13Z"
                                                      Fill="{StaticResource IconSecondary}"
                                                      Width="{StaticResource IconSizeNormal}"
                                                      Height="{StaticResource IconSizeNormal}"
                                                      Stretch="Uniform"
                                                      Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding DataContext.Localization[App.AddFolderBatch], RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </primitives:AnimatedPopup>
                        </Grid>
                        <Grid>
                            <Button x:Name="SettingsButton"
                                    Style="{StaticResource TitleBarTextButton}"
                                    Content="{Binding DataContext.Localization[App.Settings], RelativeSource={RelativeSource AncestorType=Window}}"
                                    Command="{Binding OpenSettingsPopupCommand}"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                            <primitives:AnimatedPopup x:Name="SettingsPopup"
                                   StaysOpen="True"
                                   IsOpenAnimated="{Binding IsSettingsPopupOpen}"
                                   OpenAnimationOrigin="0,0"
                                   PlacementTarget="{Binding ElementName=SettingsButton}"
                                   Placement="Bottom"
                                   HorizontalOffset="{StaticResource PopupMenuHorizontalOffset}"
                                   AllowsTransparency="True">
                                <Border Background="{StaticResource PopupMenuBackground}"
                                        CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                                        Padding="{StaticResource PopupMenuPadding}"
                                        MinWidth="{StaticResource PopupSettingsMenuMinWidth}">
                                    <StackPanel>
                                        <Grid>
                                            <Button x:Name="LanguageMenuButton"
                                                    Style="{StaticResource PopupMenuButton}"
                                                    Command="{Binding ToggleLanguageSubmenuCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DataContext.Localization[Settings.Language], RelativeSource={RelativeSource AncestorType=Window}}"
                                                               VerticalAlignment="Center"/>
                                                    <Path Data="{StaticResource ChevronRightGeometry}"
                                                          Fill="{StaticResource IconSecondary}"
                                                          Stretch="Uniform"
                                                          VerticalAlignment="Center"
                                                          Width="{StaticResource SubmenuChevronWidth}"
                                                          Height="{StaticResource SubmenuChevronHeight}"
                                                          Margin="{StaticResource SubmenuChevronLeftMargin}"/>
                                                </StackPanel>
                                            </Button>
                                            <primitives:AnimatedPopup x:Name="LanguageSubmenuPopup"
                                                   StaysOpen="True"
                                                   IsOpenAnimated="{Binding IsLanguageSubmenuOpen}"
                                                   OpenAnimationOrigin="0,0"
                                                   PlacementTarget="{Binding ElementName=LanguageMenuButton}"
                                                   Placement="Right"
                                                   HorizontalOffset="{StaticResource SubmenuPopupHorizontalOffset}"
                                                   AllowsTransparency="True">
                                                <Border Background="{StaticResource PopupMenuBackground}"
                                                        CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                                                        Padding="{StaticResource PopupMenuPadding}"
                                                        MinWidth="{StaticResource PopupSubmenuMinWidth}">
                                                    <Grid>
                                                        <Border CornerRadius="{StaticResource PopupMenuButtonCornerRadius}"
                                                                Background="{StaticResource AccentBlue}"
                                                                Height="{StaticResource SpeedOptionHeight}"
                                                                VerticalAlignment="Top">
                                                            <Border.RenderTransform>
                                                                <TranslateTransform Y="0"/>
                                                            </Border.RenderTransform>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.CurrentLanguageCode, RelativeSource={RelativeSource AncestorType=Window}}" Value="en-US">
                                                                            <DataTrigger.EnterActions>
                                                                                <BeginStoryboard Storyboard="{StaticResource SlideToSecond}"/>
                                                                            </DataTrigger.EnterActions>
                                                                            <DataTrigger.ExitActions>
                                                                                <BeginStoryboard Storyboard="{StaticResource SlideToFirst}"/>
                                                                            </DataTrigger.ExitActions>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <StackPanel>
                                                            <Button Style="{StaticResource PopupMenuButton}"
                                                                    Command="{Binding DataContext.SwitchLanguageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="zh-CN">
                                                                <TextBlock Text="中文" VerticalAlignment="Center"/>
                                                            </Button>
                                                            <Button Style="{StaticResource PopupMenuButton}"
                                                                    Command="{Binding DataContext.SwitchLanguageCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="en-US">
                                                                <TextBlock Text="English" VerticalAlignment="Center"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </primitives:AnimatedPopup>
                                        </Grid>
                                        <Grid>
                                            <Button x:Name="FullscreenAnimationMenuButton"
                                                    Style="{StaticResource PopupMenuButton}"
                                                    Command="{Binding ToggleFullscreenAnimationSubmenuCommand}"
                                                    ToolTip="{Binding DataContext.Localization[Settings.FullscreenAnimation.Tooltip], RelativeSource={RelativeSource AncestorType=Window}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DataContext.Localization[Settings.FullscreenAnimation], RelativeSource={RelativeSource AncestorType=Window}}"
                                                               VerticalAlignment="Center"/>
                                                    <Path Data="{StaticResource ChevronRightGeometry}"
                                                          Fill="{StaticResource IconSecondary}"
                                                          Stretch="Uniform"
                                                          VerticalAlignment="Center"
                                                          Width="{StaticResource SubmenuChevronWidth}"
                                                          Height="{StaticResource SubmenuChevronHeight}"
                                                          Margin="{StaticResource SubmenuChevronLeftMargin}"/>
                                                </StackPanel>
                                            </Button>
                                            <primitives:AnimatedPopup x:Name="FullscreenAnimationSubmenuPopup"
                                                   StaysOpen="True"
                                                   IsOpenAnimated="{Binding IsFullscreenAnimationSubmenuOpen}"
                                                   OpenAnimationOrigin="0,0"
                                                   PlacementTarget="{Binding ElementName=FullscreenAnimationMenuButton}"
                                                   Placement="Right"
                                                   HorizontalOffset="{StaticResource SubmenuPopupHorizontalOffset}"
                                                   AllowsTransparency="True">
                                                <Border Background="{StaticResource PopupMenuBackground}"
                                                        CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                                                        Padding="{StaticResource PopupMenuPadding}"
                                                        MinWidth="{StaticResource PopupSubmenuMinWidth}">
                                                    <Grid>
                                                        <Border CornerRadius="{StaticResource PopupMenuButtonCornerRadius}"
                                                                Background="{StaticResource AccentBlue}"
                                                                Height="{StaticResource SpeedOptionHeight}"
                                                                VerticalAlignment="Top">
                                                            <Border.RenderTransform>
                                                                <TranslateTransform Y="0"/>
                                                            </Border.RenderTransform>
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.CurrentAnimationCode, RelativeSource={RelativeSource AncestorType=Window}}" Value="continuous">
                                                                            <DataTrigger.EnterActions>
                                                                                <BeginStoryboard Storyboard="{StaticResource SlideToSecond}"/>
                                                                            </DataTrigger.EnterActions>
                                                                            <DataTrigger.ExitActions>
                                                                                <BeginStoryboard Storyboard="{StaticResource SlideToFirst}"/>
                                                                            </DataTrigger.ExitActions>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                        </Border>
                                                        <StackPanel>
                                                            <Button Style="{StaticResource PopupMenuButton}"
                                                                    Command="{Binding DataContext.SelectFullscreenAnimationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="none">
                                                                <TextBlock Text="{Binding DataContext.Localization[Settings.FullscreenAnimation.NoAnimation], RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center"/>
                                                            </Button>
                                                            <Button Style="{StaticResource PopupMenuButton}"
                                                                    Command="{Binding DataContext.SelectFullscreenAnimationCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="continuous">
                                                                <TextBlock Text="{Binding DataContext.Localization[Settings.FullscreenAnimation.ContinuousAnimation], RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </primitives:AnimatedPopup>
                                        </Grid>
                                        <Grid>
                                            <Button x:Name="PlayerInputMenuButton"
                                                    Style="{StaticResource PopupMenuButton}"
                                                    Command="{Binding TogglePlayerInputSubmenuCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding PlayerInputSettings.Title}"
                                                               VerticalAlignment="Center"/>
                                                    <Path Data="{StaticResource ChevronRightGeometry}"
                                                          Fill="{StaticResource IconSecondary}"
                                                          Stretch="Uniform"
                                                          VerticalAlignment="Center"
                                                          Width="{StaticResource SubmenuChevronWidth}"
                                                          Height="{StaticResource SubmenuChevronHeight}"
                                                          Margin="{StaticResource SubmenuChevronLeftMargin}"/>
                                                </StackPanel>
                                            </Button>
                                            <primitives:AnimatedPopup x:Name="PlayerInputSubmenuPopup"
                                                   StaysOpen="True"
                                                   IsOpenAnimated="{Binding IsPlayerInputSubmenuOpen}"
                                                   OpenAnimationOrigin="0,0"
                                                   PlacementTarget="{Binding ElementName=PlayerInputMenuButton}"
                                                   Placement="Right"
                                                   HorizontalOffset="{StaticResource SubmenuPopupHorizontalOffset}"
                                                   AllowsTransparency="True">
                                                <Border Background="{StaticResource PopupMenuBackground}"
                                                        CornerRadius="{StaticResource SpeedPopupCornerRadius}"
                                                        Padding="{StaticResource PopupMenuPadding}"
                                                        MinWidth="420">
                                                    <Grid DataContext="{Binding PlayerInputSettings}">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="{Binding HintText}"
                                                                   Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="12"
                                                                   Margin="12,8,12,10"
                                                                   TextWrapping="Wrap"/>
                                                        <ScrollViewer Grid.Row="1"
                                                                      VerticalScrollBarVisibility="Auto"
                                                                      HorizontalScrollBarVisibility="Disabled"
                                                                      MaxHeight="380">
                                                            <ItemsControl ItemsSource="{Binding Items}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="{x:Type playerSettings:PlayerInputBindingItemViewModel}">
                                                                        <Grid Margin="6,4">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="150"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Text="{Binding ActionDisplayName}"
                                                                                       VerticalAlignment="Center"
                                                                                       Margin="8,0,10,0"
                                                                                       TextTrimming="CharacterEllipsis"/>
                                                                            <Button Grid.Column="1"
                                                                                    Style="{StaticResource PopupMenuButton}"
                                                                                    HorizontalContentAlignment="Left"
                                                                                    MinWidth="140"
                                                                                    Command="{Binding DataContext.BeginCaptureCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                    CommandParameter="{Binding Index}">
                                                                                <TextBlock Text="{Binding BindingDisplay}">
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Text" Value="{Binding BindingDisplay}"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                                                                    <Setter Property="Text" Value="{Binding DataContext.CapturingButtonText, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </Button>
                                                                            <Button Grid.Column="2"
                                                                                    Style="{StaticResource PopupMenuButton}"
                                                                                    Margin="6,0,0,0"
                                                                                    Command="{Binding DataContext.BeginCaptureCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                    CommandParameter="{Binding Index}">
                                                                                <TextBlock>
                                                                                    <TextBlock.Style>
                                                                                        <Style TargetType="TextBlock">
                                                                                            <Setter Property="Text" Value="{Binding DataContext.CaptureButtonText, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsCapturing}" Value="True">
                                                                                                    <Setter Property="Text" Value="{Binding DataContext.CapturingButtonText, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </TextBlock.Style>
                                                                                </TextBlock>
                                                                            </Button>
                                                                            <Button Grid.Column="3"
                                                                                    Style="{StaticResource PopupMenuButton}"
                                                                                    Margin="6,0,0,0"
                                                                                    Command="{Binding DataContext.ClearBindingCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                                    CommandParameter="{Binding Index}">
                                                                                <TextBlock Text="{Binding DataContext.ClearButtonText, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                                            </Button>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </ScrollViewer>
                                                        <Button Grid.Row="2"
                                                                Style="{StaticResource PopupMenuButton}"
                                                                HorizontalContentAlignment="Center"
                                                                Margin="6,10,6,6"
                                                                Command="{Binding ResetCommand}">
                                                            <TextBlock Text="{Binding ResetButtonText}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </primitives:AnimatedPopup>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </primitives:AnimatedPopup>
                        </Grid>
                    </StackPanel>

                    <Grid x:Name="TitleBarDragZone" Grid.Column="1"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="MinimizeButton"
                                Style="{StaticResource TitleBarIconButton}"
                                Width="{StaticResource TitleBarButtonWidth}"
                                Height="{StaticResource TitleBarButtonHeight}"
                                Click="MinimizeButton_Click" ToolTip="{Binding DataContext.Localization[Window.Minimize], RelativeSource={RelativeSource AncestorType=Window}}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="{StaticResource TitleBarIconSize}"
                                     Height="{StaticResource TitleBarIconSize}">
                                <Path Data="{StaticResource MinimizeIconGeometry}" Stroke="White"
                                      StrokeThickness="{StaticResource TitleBarIconStroke}"
                                      StrokeEndLineCap="Round"/>
                            </Viewbox>
                        </Button>

                        <Button x:Name="MaximizeButton"
                                Click="MaximizeButton_Click"
                                Width="{StaticResource TitleBarButtonWidth}"
                                Height="{StaticResource TitleBarButtonHeight}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="{StaticResource TitleBarIconSize}"
                                     Height="{StaticResource TitleBarIconSize}">
                                <Path Stroke="White"
                                      StrokeThickness="{StaticResource TitleBarIconStroke}"
                                      StrokeLineJoin="Round">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data"
                                                    Value="{StaticResource MaximizeIconGeometry}"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="Maximized"
                                                    Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <Setter Property="Data"
                                                            Value="{StaticResource RestoreIconGeometry}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Viewbox>
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource TitleBarIconButton}">
                                    <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Window.Maximize], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="Maximized"
                                            Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Setter Property="ToolTip" Value="{Binding DataContext.Localization[Window.Restore], RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button x:Name="CloseButton"
                                Style="{StaticResource CloseIconButton}"
                                Width="{StaticResource TitleBarButtonWidth}"
                                Height="{StaticResource TitleBarButtonHeight}"
                                Click="CloseButton_Click" ToolTip="{Binding DataContext.Localization[Window.Close], RelativeSource={RelativeSource AncestorType=Window}}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="{StaticResource TitleBarIconSize}"
                                     Height="{StaticResource TitleBarIconSize}">
                                <Path Data="{StaticResource CloseIconGeometry}" Stroke="White"
                                      StrokeThickness="{StaticResource TitleBarIconStroke}"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <primitives:TransitioningContentControl x:Name="PageTransition"
                Grid.Row="1" Content="{Binding CurrentPage}"/>
        </Grid>
    </Border>
</Window>



