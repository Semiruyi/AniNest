<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App logo: play triangle -->
    <Geometry x:Key="AppIconGeometry">M1,0.5 L8.5,5 L1,9.5 Z</Geometry>

    <!-- Title bar window control icons -->
    <Geometry x:Key="MinimizeIconGeometry">M2.5,7.5 L7.5,7.5</Geometry>
    <Geometry x:Key="MaximizeIconGeometry">M2,2 L8,2 L8,8 L2,8 Z</Geometry>
    <Geometry x:Key="RestoreIconGeometry">M4,2 L8,2 L8,6 L4,6 Z M2,4 L6,4 L6,8 L2,8 Z</Geometry>
    <Geometry x:Key="CloseIconGeometry">M2,2 L8,8 M8,2 L2,8</Geometry>

</ResourceDictionary>
