<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:animations="clr-namespace:LocalPlayer.View.Animations">

    <!-- 统一的圆形悬浮图标按钮：合并了原 IconButton 和 PlayButton。
         使用方式：<Button Style="{StaticResource IconButton}" Width="36" Content="..." />
         ButtonScaleHover.IsEnabled 可附加 hover/press 缩放动画。 -->
    <Style x:Key="IconButton" TargetType="Button">
        <Style.Resources>
            <CornerRadius x:Key="ButtonCornerRadius">8</CornerRadius>
        </Style.Resources>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="0.8"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="ButtonGrid" RenderTransformOrigin="0.5,0.5"
                          Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="HoverBg" CornerRadius="{DynamicResource ButtonCornerRadius}"
                                Background="{DynamicResource HoverBackground}" Opacity="0"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- 标题栏图标按钮：基于 IconButton，覆盖圆角 -->
    <Style x:Key="TitleBarIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Style.Resources>
            <CornerRadius x:Key="ButtonCornerRadius">0</CornerRadius>
        </Style.Resources>
    </Style>

    <!-- 标题栏关闭按钮：基于 IconButton，hover 红色，覆盖圆角 -->
    <Style x:Key="CloseIconButton" TargetType="Button" BasedOn="{StaticResource IconButton}">
        <Style.Resources>
            <SolidColorBrush x:Key="HoverBackground" Color="#E81123"/>
            <CornerRadius x:Key="ButtonCornerRadius">0</CornerRadius>
        </Style.Resources>
    </Style>

    <!-- 删除图标按钮：红色圆形，Content 自由设置图标 -->
    <Style x:Key="DeleteIconButton" TargetType="Button">
        <Setter Property="Width" Value="26"/>
        <Setter Property="Height" Value="26"/>
        <Setter Property="Background" Value="#CCFF4444"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Ellipse Fill="{TemplateBinding Background}"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
