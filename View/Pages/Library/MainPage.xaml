<UserControl x:Class="LocalPlayer.View.Pages.Library.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:LocalPlayer.View.Behaviors"
             xmlns:animations="clr-namespace:LocalPlayer.View.Animations"
             xmlns:loc="clr-namespace:LocalPlayer.Localization"
             behaviors:LoadedCommandBehavior.Command="{Binding LoadDataCommand}"
             Background="{StaticResource BackgroundDark}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl Margin="{StaticResource LibraryPageMargin}"
                          ItemsSource="{Binding FolderItems}"
                          animations:StaggeredItemsAnimation.Enabled="True"
                          animations:StaggeredItemsAnimation.StaggerMs="50"
                          animations:StaggeredItemsAnimation.DurationMs="500">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="{StaticResource FolderCardWidth}"
                                Height="{StaticResource FolderCardHeight}"
                                Margin="{StaticResource FolderCardMargin}"
                                Background="{StaticResource SurfaceDark}"
                                CornerRadius="{StaticResource FolderCardCornerRadius}"
                                Cursor="Hand"
                                behaviors:MouseGestureBehavior.LeftClick="{Binding DataContext.SelectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                behaviors:MouseGestureBehavior.CommandParameter="{Binding}"
                                animations:CardAnimation.Enabled="True"
                                animations:CardAnimation.HoverDurationMs="250"
                                animations:CardAnimation.PressDipMs="100"
                                animations:CardAnimation.PressRecoverMs="350"
                                animations:CardAnimation.CoverScale="1.12"
                                animations:CardAnimation.CoverShiftY="-8"
                                animations:CardAnimation.CoverDurationMs="400">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.35"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.Clip>
                                    <RectangleGeometry RadiusX="10" RadiusY="10"
                                                      Rect="0,0,190,253"/>
                                </Grid.Clip>

                                <!-- 删除按钮 -->
                                <Button Style="{StaticResource DeleteIconButton}"
                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6"
                                        Command="{Binding DataContext.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Panel.ZIndex="10">
                                    <TextBlock Text="&#x2715;" FontSize="12" Margin="0,-1,0,0"/>
                                </Button>

                                <!-- 封面图 -->
                                <Image Stretch="UniformToFill" Source="{Binding CoverPath}">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>

                                <!-- 无封面占位 -->
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Rectangle Fill="#252525"/>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F3AC;" FontSize="32" HorizontalAlignment="Center"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding [Library.NoCover], Source={x:Static loc:LocalizationService.Instance}}" Foreground="#666666" FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 底部渐变遮罩 + 信息 -->
                                <Grid VerticalAlignment="Bottom">
                                    <Rectangle Height="{StaticResource FolderCardGradientHeight}">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="#E6000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel Margin="{StaticResource CardInfoMargin}">
                                        <TextBlock Text="{Binding Name}" Foreground="White"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding VideoCountText}"
                                                   Foreground="#BBBBBB" FontSize="11" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</UserControl>
