<UserControl x:Class="LocalPlayer.View.Pages.Library.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:LocalPlayer.View.Behaviors"
             xmlns:animations="clr-namespace:LocalPlayer.View.Animations"
             behaviors:LoadedCommandBehavior.Command="{Binding LoadDataCommand}"

             Background="{StaticResource BackgroundDark}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl Margin="24" ItemsSource="{Binding FolderItems}"
                          animations:StaggeredItemsAnimation.Enabled="True"
                          animations:StaggeredItemsAnimation.StaggerMs="50"
                          animations:StaggeredItemsAnimation.DurationMs="500">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="190" Height="253" Margin="12"
                                Background="{StaticResource SurfaceDark}"
                                CornerRadius="10" Cursor="Hand"
                                behaviors:MouseGestureBehavior.LeftClick="{Binding DataContext.SelectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                behaviors:MouseGestureBehavior.CommandParameter="{Binding}"
                                animations:CardAnimation.Enabled="True"
                                animations:CardAnimation.HoverDurationMs="250"
                                animations:CardAnimation.PressDipMs="100"
                                animations:CardAnimation.PressRecoverMs="350"
                                animations:CardAnimation.CoverScale="1.12"
                                animations:CardAnimation.CoverShiftY="-8"
                                animations:CardAnimation.CoverDurationMs="400">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="3" Opacity="0.35"/>
                            </Border.Effect>
                            <Grid>
                                <Grid.Clip>
                                    <RectangleGeometry RadiusX="10" RadiusY="10" Rect="0,0,190,253"/>
                                </Grid.Clip>

                                <!-- 删除按钮 -->
                                <Button Width="26" Height="26" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="6"
                                        Background="#CCFF4444" Foreground="White" BorderThickness="0"
                                        Command="{Binding DataContext.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand" Panel.ZIndex="10">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid>
                                                <Ellipse Fill="{TemplateBinding Background}"/>
                                                <TextBlock Text="&#x2715;" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- 封面图 -->
                                <Image Stretch="UniformToFill" Source="{Binding CoverPath}">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>

                                <!-- 无封面占位 -->
                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Rectangle Fill="#252525"/>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="&#x1F3AC;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="暂无封面" Foreground="#666666" FontSize="13"/>
                                    </StackPanel>
                                </Grid>

                                <!-- 底部渐变遮罩 + 信息 -->
                                <Grid VerticalAlignment="Bottom">
                                    <Rectangle Height="100">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="#E6000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <StackPanel Margin="12,44,12,12">
                                        <TextBlock Text="{Binding Name}" Foreground="White"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding VideoCount, StringFormat='{}{0} 个视频'}"
                                                   Foreground="#BBBBBB" FontSize="11" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 底部工具栏 -->
        <Border Grid.Row="1" Height="64" Background="{StaticResource SurfaceDark}">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="-4" Opacity="0.3"/>
            </Border.Effect>
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：文件夹统计信息 + 缩略图生成进度 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding FolderCountText}" Foreground="{StaticResource TextSecondary}" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ThumbnailProgressText}" Foreground="{StaticResource TextSecondary}" FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0"
                               Visibility="{Binding IsThumbnailProgressVisible, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- 中间：快速操作提示（空状态时显示） -->
                <TextBlock x:Name="EmptyHintText" Grid.Column="1" Text="添加文件夹开始浏览视频" Foreground="{StaticResource TextSecondary}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>

                <!-- 右侧：操作按钮组 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <!-- 设置按钮 -->
                    <Button x:Name="SettingsBtn" Width="36" Height="36" Margin="0,0,12,0"
                            Style="{StaticResource IconButton}"
                            Command="{Binding SettingsCommand}" Opacity="0.7"
                            ToolTip="设置"
                            animations:ButtonScaleHover.IsEnabled="True"
                            animations:ButtonScaleHover.HoverScale="1.15"
                            animations:ButtonScaleHover.PressScale="0.9">
                        <TextBlock Text="&#x2699;" FontSize="18" Foreground="White"/>
                    </Button>

                    <!-- 添加文件夹主按钮 -->
                    <Button x:Name="AddFolderBtn" Command="{Binding AddFolderCommand}" Cursor="Hand"
                            animations:ButtonScaleHover.IsEnabled="True"
                            animations:ButtonScaleHover.HoverScale="1.04"
                            animations:ButtonScaleHover.PressScale="0.96">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Height" Value="38"/>
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="BtnBorder"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="10"
                                                    Height="{TemplateBinding Height}"
                                                    Padding="{TemplateBinding Padding}"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="{StaticResource AccentBlueColor}" BlurRadius="0" ShadowDepth="0" Opacity="0"/>
                                                </Border.Effect>
                                                <Border.RenderTransform>
                                                    <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                                                </Border.RenderTransform>
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="&#x2795;" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="添加文件夹" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="BtnBorder" Property="Background" Value="{StaticResource AccentBlueHover}"/>
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="16" Duration="0:0:0.15"/>
                                                                <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0.4" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)" To="0" Duration="0:0:0.2"/>
                                                                <DoubleAnimation Storyboard.TargetName="BtnBorder" Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)" To="0" Duration="0:0:0.2"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
