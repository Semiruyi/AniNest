<UserControl x:Class="LocalPlayer.View.Pages.Player.PlayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LocalPlayer.View.Pages.Player"
             xmlns:anim="clr-namespace:LocalPlayer.View.Animations"
             xmlns:conv="clr-namespace:LocalPlayer.View.Converters"
             xmlns:behaviors="clr-namespace:LocalPlayer.View.Behaviors"
             xmlns:primitives="clr-namespace:LocalPlayer.View.Primitives"
             xmlns:converters="clr-namespace:LocalPlayer.View.Converters"
             Background="{StaticResource BackgroundDark}"
             Focusable="True"
             behaviors:LoadedCommandBehavior.FocusOnLoaded="True"
             behaviors:LoadedCommandBehavior.UnloadedCommand="{Binding CleanupCommand}"
             behaviors:KeyboardBehavior.KeyDownCommand="{Binding KeyDownCommand}">
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolConverter x:Key="InverseBool"/>
            <converters:ProgressToPieConverter x:Key="ProgressToPieConverter"/>
            <converters:ProgressToVisibilityConverter x:Key="ProgressToVisibilityConverter"/>

            <Style x:Key="EpisodeButton" TargetType="Button">
                <Setter Property="Width" Value="54"/>
                <Setter Property="Height" Value="54"/>
                <Setter Property="Foreground" Value="#EBEBF5"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei, sans-serif"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="ButtonRoot" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Border x:Name="BgBorder" CornerRadius="14">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="BgBrush" Color="#2C2C2E"/>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" BlurRadius="4"
                                                          ShadowDepth="1" Direction="270" Opacity="0.12"/>
                                    </Border.Effect>
                                </Border>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <!-- 已看对勾 -->
                                <Grid x:Name="CheckIcon" HorizontalAlignment="Right" VerticalAlignment="Top"
                                      Width="20" Height="20" Margin="0,-3,-3,0"
                                      Opacity="0" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform ScaleX="0" ScaleY="0"/>
                                    </Grid.RenderTransform>
                                    <Ellipse Fill="White" Width="20" Height="20"/>
                                    <Image Source="/Resources/Icons/check.png" Width="20" Height="20">
                                        <Image.Clip>
                                            <EllipseGeometry RadiusX="10" RadiusY="10" Center="10,10"/>
                                        </Image.Clip>
                                    </Image>
                                </Grid>
                                <!-- 生成进度饼图 -->
                                <Grid HorizontalAlignment="Right" VerticalAlignment="Top"
                                      Width="20" Height="20" Margin="0,-3,-3,0"
                                      Visibility="{Binding ThumbnailProgress, Converter={StaticResource ProgressToVisibilityConverter}}">
                                    <Ellipse Fill="#48484A" Width="20" Height="20"/>
                                    <Path Fill="{StaticResource AccentBlue}" Opacity="0.85"
                                          Width="20" Height="20"
                                          Data="{Binding ThumbnailProgress, Converter={StaticResource ProgressToPieConverter}}"/>
                                </Grid>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ButtonRoot"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="1.04" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ButtonRoot"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="1.04" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="BgBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#3A3A3C" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ButtonRoot"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ButtonRoot"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="BgBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    Duration="0:0:0.25" FillBehavior="Stop"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Foreground" Value="#EBEBF5"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ButtonRoot"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="0.96" Duration="0:0:0.08">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ButtonRoot"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="0.96" Duration="0:0:0.08">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="BgBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#1C1C1E" Duration="0:0:0.08"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ButtonRoot"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="1" Duration="0:0:0.4">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="ButtonRoot"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="1" Duration="0:0:0.4">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <ColorAnimation Storyboard.TargetName="BgBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    Duration="0:0:0.25" FillBehavior="Stop"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <DataTrigger Binding="{Binding IsPlayed}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="BgBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#165396" Duration="0:0:0.22"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsThumbnailReady}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="CheckIcon"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    From="0" To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="CheckIcon"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    From="0" To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="CheckIcon"
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="0" To="1" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="BgBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#007AFF" Duration="0:0:0.22"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="BgBrush"
                                                    Storyboard.TargetProperty="Color"
                                                    To="#165396" Duration="0:0:0.22"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Width" Value="4"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid>
                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Background="#28FFFFFF"
                                                            CornerRadius="2"
                                                            Width="4"/>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="3"/>
                <Setter Property="Width" Value="54"/>
                <Setter Property="Height" Value="54"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <ContentPresenter/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid x:Name="PageRoot" anim:LoadedAnimator.Enabled="True">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频区 -->
        <Grid x:Name="VideoContainer" Grid.Row="0" Grid.Column="0" Background="Black"
              behaviors:MouseGestureBehavior.LeftClick="{Binding PlayPauseCommand}"
              behaviors:MouseGestureBehavior.XButton1="{Binding GoBackCommand}"
              behaviors:MouseGestureBehavior.RightHold="{Binding EnterRightHoldCommand}"
              behaviors:MouseGestureBehavior.RightHoldRelease="{Binding ExitRightHoldCommand}">
            <Image x:Name="VideoImage" Stretch="Uniform" Source="{Binding VideoSource}"/>
            <!-- 暂停大图标（右下角） -->
            <Image x:Name="PauseBigIcon"
                   Source="/Resources/Icons/pause-big.png"
                   Width="80" Height="80"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,32,24"
                   Opacity="0"
                   RenderTransformOrigin="0.5,0.5"
                   anim:PopupAnimator.BindVisible="{Binding IsPlaying, Converter={StaticResource InverseBool}}">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="PauseBigIconScale" ScaleX="0" ScaleY="0"/>
                </Image.RenderTransform>
            </Image>
        </Grid>

        <!-- 选集面板 -->
        <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Width="276" Background="#1A1A1C"
                BorderBrush="#222224" BorderThickness="1,0,0,0"
                DataContext="{Binding Playlist}"
                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="20,18,20,10">
                    <TextBlock Text="选集" Foreground="White" FontSize="15"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EpisodeCountText, FallbackValue=''}" Foreground="#8E8E93" FontSize="12"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Episode Grid -->
                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Margin="14,4,14,14"
                         ItemsSource="{Binding Items}"
                         SelectedIndex="{Binding CurrentIndex, Mode=OneWay}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <primitives:AnimatedWrapPanel Orientation="Horizontal"
                                                     AnimationDuration="0:0:0.2"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource EpisodeButton}"
                                    Command="{Binding DataContext.PlayEpisodeCommand, RelativeSource={RelativeSource AncestorType=Border}}"
                                    CommandParameter="{Binding}">
                                <TextBlock Text="{Binding Number, StringFormat={}{0:D2}}"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                           FontSize="15"
                                           FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.ToolTip>
                                        <ToolTip Background="#1C1C1E" BorderBrush="#38383A"
                                                 Foreground="White" Padding="10,5" BorderThickness="1"
                                                 FontSize="12">
                                            <TextBlock Text="{Binding Title}" MaxWidth="220"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 控制栏 -->
        <local:ControlBarView x:Name="ControlBar"
                              Grid.Row="1" Grid.Column="0"
                              DataContext="{Binding ControlBar}"/>
    </Grid>
</UserControl>
