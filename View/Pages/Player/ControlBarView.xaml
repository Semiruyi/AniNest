<UserControl x:Class="LocalPlayer.View.Pages.Player.ControlBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:LocalPlayer.View.Converters"
             xmlns:animations="clr-namespace:LocalPlayer.View.Animations"
             xmlns:behaviors="clr-namespace:LocalPlayer.View.Behaviors"
             Focusable="True">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:IsSpeedMatchConverter x:Key="IsSpeedMatchConverter"/>

            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="36"/>
                <Setter Property="Height" Value="36"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Opacity" Value="0.8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="ButtonGrid" RenderTransformOrigin="0.5,0.5"
                                  Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Ellipse x:Name="HoverBg" Fill="{StaticResource HoverBackground}"
                                         Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PlayButton" TargetType="Button">
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Width" Value="34"/>
                <Setter Property="Height" Value="34"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Opacity" Value="0.85"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid x:Name="ButtonGrid" RenderTransformOrigin="0.5,0.5"
                                  Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="AnimScale" ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Ellipse x:Name="HoverBg" Fill="{StaticResource HoverBackground}"
                                         Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" Opacity="0"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SpeedOptionButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="34"/>
                <Setter Property="Width" Value="78"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="BgBorder" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                                <Border.Background>
                                    <SolidColorBrush x:Name="BgBrush" Color="Transparent"/>
                                </Border.Background>
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <Border x:Name="HoverOverlay" CornerRadius="8"
                                            Background="#33FFFFFF" Opacity="0"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="1" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                    Storyboard.TargetProperty="Opacity"
                                                    To="0" Duration="0:0:0.3"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BgBorder"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="0.95" Duration="0:0:0.06"/>
                                                <DoubleAnimation Storyboard.TargetName="BgBorder"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="0.95" Duration="0:0:0.06"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BgBorder"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                    To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <ElasticEase Oscillations="1" Springiness="8" EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                                <DoubleAnimation Storyboard.TargetName="BgBorder"
                                                    Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                    To="1" Duration="0:0:0.25">
                                                    <DoubleAnimation.EasingFunction>
                                                        <ElasticEase Oscillations="1" Springiness="8" EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Value="True">
                        <DataTrigger.Binding>
                            <MultiBinding Converter="{StaticResource IsSpeedMatchConverter}">
                                <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                                <Binding Path="PlacementTarget.DataContext.Rate" ElementName="SpeedPopup"/>
                            </MultiBinding>
                        </DataTrigger.Binding>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="FontSize" Value="14"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="SliderDecreaseButton" TargetType="RepeatButton">
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Focusable" Value="false"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Grid Background="Transparent" VerticalAlignment="Stretch">
                                <Border Background="{StaticResource AccentBlue}" Height="4" CornerRadius="2" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SliderIncreaseButton" TargetType="RepeatButton">
                <Setter Property="OverridesDefaultStyle" Value="true"/>
                <Setter Property="IsTabStop" Value="false"/>
                <Setter Property="Focusable" Value="false"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Grid Background="Transparent" VerticalAlignment="Stretch">
                                <Border Background="#33FFFFFF" Height="4" CornerRadius="2" VerticalAlignment="Center"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SliderThumb" TargetType="Thumb">
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Grid x:Name="ThumbGrid" RenderTransformOrigin="0.5,0.5">
                                <Grid.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Ellipse x:Name="ThumbShadow" Fill="{StaticResource AccentBlue}" Width="16" Height="16" Opacity="0.25"/>
                                <Ellipse x:Name="ThumbBg" Fill="White" Width="12" Height="12"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbBg" Property="Width" Value="14"/>
                                    <Setter TargetName="ThumbBg" Property="Height" Value="14"/>
                                    <Setter TargetName="ThumbShadow" Property="Width" Value="20"/>
                                    <Setter TargetName="ThumbShadow" Property="Height" Value="20"/>
                                    <Setter TargetName="ThumbShadow" Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ModernSlider" TargetType="Slider">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource AccentBlue}"/>
                <Setter Property="Height" Value="22"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid x:Name="GridRoot" VerticalAlignment="Center" Height="22" Background="{TemplateBinding Background}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="7"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="7"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="1" Background="#33FFFFFF" Height="4" CornerRadius="2" VerticalAlignment="Center"/>
                                <Track x:Name="PART_Track" Grid.Column="1" VerticalAlignment="Stretch">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource SliderDecreaseButton}" Command="Slider.DecreaseLarge"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource SliderIncreaseButton}" Command="Slider.IncreaseLarge"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource SliderThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="PART_Track" Property="Height" Value="22"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid x:Name="RootGrid" Height="63"
          Focusable="True"
          behaviors:KeyboardBehavior.KeyDownCommand="{Binding KeyDownCommand}">
        <Grid.Background>
            <SolidColorBrush Color="#CC0F0F0F"/>
        </Grid.Background>

        <Grid Margin="10,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：播放控制 + 时间 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Button x:Name="PreviousBtn" Style="{StaticResource IconButton}" Command="{Binding PreviousCommand}" ToolTip="{Binding PreviousTooltip}" Focusable="False"
                        animations:ButtonScaleHover.IsEnabled="True">
                    <Image Source="/Resources/Icons/previous.png" Width="14" Height="14"/>
                </Button>
                <Button x:Name="PlayPauseBtn" Style="{StaticResource PlayButton}" Command="{Binding PlayPauseCommand}" Margin="2,0" ToolTip="{Binding PlayPauseTooltip}" Focusable="False"
                        animations:ButtonScaleHover.IsEnabled="True">
                    <Image x:Name="PlayPauseIcon" Width="20" Height="20">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Source" Value="/Resources/Icons/play.png"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Source" Value="/Resources/Icons/pause.png"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Image.Style>
                    </Image>
                </Button>
                <Button x:Name="NextBtn" Style="{StaticResource IconButton}" Command="{Binding NextCommand}" ToolTip="{Binding NextTooltip}" Focusable="False"
                        animations:ButtonScaleHover.IsEnabled="True">
                    <Image Source="/Resources/Icons/next.png" Width="14" Height="14"/>
                </Button>
                <Button x:Name="StopBtn" Style="{StaticResource IconButton}" Command="{Binding StopCommand}" Margin="2,0,0,0" ToolTip="停止" Focusable="False">
                    <Image Source="/Resources/Icons/stop.png" Width="14" Height="14"/>
                </Button>
                <TextBlock Text="{Binding CurrentTimeText, FallbackValue='00:00'}"
                           Foreground="{StaticResource TextSecondary}" FontSize="11"
                           VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                <TextBlock Text=" / " Foreground="#66FFFFFF" FontSize="11"
                           VerticalAlignment="Center" Margin="2,0"/>
                <TextBlock Text="{Binding TotalTimeText, FallbackValue='00:00'}"
                           Foreground="{StaticResource TextSecondary}" FontSize="11"
                           VerticalAlignment="Center" FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
            </StackPanel>

            <!-- 中间：进度条 -->
            <Slider x:Name="ProgressSlider" Grid.Column="1"
                    Style="{StaticResource ModernSlider}"
                    Value="{Binding CurrentTime}"
                    Maximum="{Binding TotalTime}"
                    behaviors:SeekSliderBehavior.IsSeeking="{Binding IsSeeking, Mode=TwoWay}"
                    behaviors:SeekSliderBehavior.SeekCommand="{Binding SeekCommand}"
                    behaviors:HoverBehavior.MouseEnterCommand="{Binding ThumbnailPreview.EnterCommand}"
                    behaviors:HoverBehavior.MouseLeaveCommand="{Binding ThumbnailPreview.LeaveCommand}"
                    behaviors:MouseMoveBehavior.MouseMoveCommand="{Binding ThumbnailPreview.MoveCommand}"
                    VerticalAlignment="Center"
                    Margin="10,0"/>

            <!-- 进度条悬浮预览弹窗（状态由 ViewModel 控制） -->
            <Popup x:Name="ProgressPopup" AllowsTransparency="True"
                   Placement="Relative" StaysOpen="True"
                   PlacementTarget="{Binding ElementName=ProgressSlider}"
                   HorizontalOffset="{Binding ThumbnailPreview.HOffset}"
                   VerticalOffset="-120"
                   animations:PopupAnimator.BindOpen="{Binding ThumbnailPreview.IsOpen}"
                   behaviors:HoverBehavior.MouseEnterCommand="{Binding ThumbnailPreview.PopupEnterCommand}"
                   behaviors:HoverBehavior.MouseLeaveCommand="{Binding ThumbnailPreview.PopupLeaveCommand}">
                <Border CornerRadius="10" ClipToBounds="True"
                        Width="160" Height="90" Background="#1A1A1C"
                        RenderTransformOrigin="0.5,1"
                        Opacity="0">
                    <Border.Clip>
                        <RectangleGeometry RadiusX="10" RadiusY="10" Rect="0,0,160,90"/>
                    </Border.Clip>
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
                    </Border.RenderTransform>
                    <Grid>
                        <Image Stretch="UniformToFill"
                               Width="160" Height="90"
                               Source="{Binding ThumbnailPreview.ImageSource}"
                               Visibility="{Binding ThumbnailPreview.ImageVisibility}"/>
                        <Border Background="#CC000000" CornerRadius="4"
                                Padding="6,3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom">
                            <TextBlock Foreground="White"
                                       FontSize="12"
                                       FontFamily="Segoe UI, Microsoft YaHei, sans-serif"
                                       Text="{Binding ThumbnailPreview.TimeText}"/>
                        </Border>
                    </Grid>
                </Border>
            </Popup>

            <!-- 右侧：倍速 + 菜单 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- 倍速按钮 + 弹出列表 -->
                <Grid>
                    <Button x:Name="SpeedBtn" Content="{Binding Rate, StringFormat={}{0:0.##}x}"
                            Style="{StaticResource IconButton}"
                            FontSize="11" FontWeight="SemiBold"
                            Foreground="White" Focusable="False"
                            Margin="0,0,2,0"
                            behaviors:HoverBehavior.MouseEnterCommand="{Binding SpeedEnterCommand}"
                            behaviors:HoverBehavior.MouseLeaveCommand="{Binding SpeedLeaveCommand}"/>
                    <Popup x:Name="SpeedPopup" AllowsTransparency="True"
                           Placement="Center"
                           PlacementTarget="{Binding ElementName=SpeedBtn}"
                           StaysOpen="True"
                           VerticalOffset="-40"
                           animations:PopupAnimator.BindOpen="{Binding IsSpeedPopupOpen}">
                        <Border Background="#E6282828" CornerRadius="12" Padding="4"
                                RenderTransformOrigin="0.5,1"
                                Opacity="0"
                                behaviors:HoverBehavior.MouseEnterCommand="{Binding SpeedEnterCommand}"
                                behaviors:HoverBehavior.MouseLeaveCommand="{Binding SpeedLeaveCommand}">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="SpeedPopupScale" ScaleX="0" ScaleY="0"/>
                            </Border.RenderTransform>
                            <ItemsControl x:Name="SpeedOptionsPanel"
                                          ItemsSource="{Binding SpeedOptions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Style="{StaticResource SpeedOptionButtonStyle}"
                                                Content="{Binding StringFormat={}{0:0.##}x}"
                                                Tag="{Binding}"
                                                Command="{Binding DataContext.ChangeSpeedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <animations:HighlightBrush.IsActive>
                                                <MultiBinding Converter="{StaticResource IsSpeedMatchConverter}">
                                                    <Binding Path="Tag" RelativeSource="{RelativeSource Self}"/>
                                                    <Binding Path="PlacementTarget.DataContext.Rate" ElementName="SpeedPopup"/>
                                                </MultiBinding>
                                            </animations:HighlightBrush.IsActive>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </Grid>

                <Button x:Name="PlaylistToggleBtn" Style="{StaticResource IconButton}" Command="{Binding TogglePlaylistCommand}" ToolTip="选集" Focusable="False">
                    <Image Source="/Resources/Icons/playlist.png" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
