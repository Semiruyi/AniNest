<Window x:Class="LocalPlayer.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:LocalPlayer.View.Primitives"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="LocalPlayer"
        Height="{StaticResource WindowDefaultHeight}"
        Width="{StaticResource WindowDefaultWidth}"
        MinWidth="{StaticResource WindowMinWidth}"
        MinHeight="{StaticResource WindowMinHeight}"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="{StaticResource TitleBarHeight}"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border ClipToBounds="True"
            Background="{StaticResource BackgroundDark}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="{StaticResource WindowCornerRadius}"/>
                <Style.Triggers>
                    <DataTrigger Value="Maximized"
                        Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Setter Property="CornerRadius" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition x:Name="TitleBarRow" Height="{StaticResource TitleBarRowHeight}"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource BackgroundDark}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：App 图标 + 工具栏按钮 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="{StaticResource TitleBarLeftMargin}">
                        <Viewbox Width="{StaticResource TitleBarAppIconSize}"
                                 Height="{StaticResource TitleBarAppIconSize}"
                                 VerticalAlignment="Center">
                            <Path Data="{StaticResource AppIconGeometry}"
                                  Fill="{StaticResource AccentBlue}"/>
                        </Viewbox>
                        <Button Style="{StaticResource TitleBarTextButton}"
                                Content="File"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Style="{StaticResource TitleBarTextButton}"
                                Content="Settings"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>

                    <!-- 中间拖拽区域 -->
                    <Grid Grid.Column="1"/>

                    <!-- 右侧：窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button Style="{StaticResource TitleBarIconButton}"
                                Width="{StaticResource TitleBarButtonWidth}"
                                Height="{StaticResource TitleBarButtonHeight}"
                                Click="MinimizeButton_Click" ToolTip="最小化"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="{StaticResource TitleBarIconSize}"
                                     Height="{StaticResource TitleBarIconSize}">
                                <Path Data="{StaticResource MinimizeIconGeometry}" Stroke="White"
                                      StrokeThickness="{StaticResource TitleBarIconStroke}"
                                      StrokeEndLineCap="Round"/>
                            </Viewbox>
                        </Button>

                        <Button Click="MaximizeButton_Click"
                                Width="{StaticResource TitleBarButtonWidth}"
                                Height="{StaticResource TitleBarButtonHeight}"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="{StaticResource TitleBarIconSize}"
                                     Height="{StaticResource TitleBarIconSize}">
                                <Path Stroke="White"
                                      StrokeThickness="{StaticResource TitleBarIconStroke}"
                                      StrokeLineJoin="Round">
                                    <Path.Style>
                                        <Style TargetType="Path">
                                            <Setter Property="Data"
                                                    Value="{StaticResource MaximizeIconGeometry}"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="Maximized"
                                                    Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                                    <Setter Property="Data"
                                                            Value="{StaticResource RestoreIconGeometry}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Path.Style>
                                </Path>
                            </Viewbox>
                            <Button.Style>
                                <Style TargetType="Button"
                                       BasedOn="{StaticResource TitleBarIconButton}">
                                    <Setter Property="ToolTip" Value="最大化"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="Maximized"
                                            Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Setter Property="ToolTip" Value="还原"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Style="{StaticResource CloseIconButton}"
                                Width="{StaticResource TitleBarButtonWidth}"
                                Height="{StaticResource TitleBarButtonHeight}"
                                Click="CloseButton_Click" ToolTip="关闭"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="{StaticResource TitleBarIconSize}"
                                     Height="{StaticResource TitleBarIconSize}">
                                <Path Data="{StaticResource CloseIconGeometry}" Stroke="White"
                                      StrokeThickness="{StaticResource TitleBarIconStroke}"
                                      StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 页面内容 -->
            <primitives:TransitioningContentControl Grid.Row="1"
                Content="{Binding CurrentPage}"/>
        </Grid>
    </Border>
</Window>
