<Window x:Class="LocalPlayer.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:behaviors="clr-namespace:LocalPlayer.View.Behaviors"
        xmlns:primitives="clr-namespace:LocalPlayer.View.Primitives"
        behaviors:WindowChromeBehavior.IsDarkTitleBar="True"
        behaviors:WindowChromeBehavior.CaptionColor="#00000000"
        Title="LocalPlayer" Height="720" Width="1280"
        MinWidth="800" MinHeight="500"
        Background="{StaticResource BackgroundDark}"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <primitives:TransitioningContentControl Content="{Binding CurrentPage}"/>
    </Grid>
</Window>
