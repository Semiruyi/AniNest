<Window x:Class="LocalPlayer.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:LocalPlayer.View.Primitives"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="LocalPlayer" Height="720" Width="1280"
        MinWidth="800" MinHeight="500"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="36" ResizeBorderThickness="6"
                            GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border ClipToBounds="True"
            Background="{StaticResource BackgroundDark}">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="CornerRadius" Value="8"/>
                <Style.Triggers>
                    <DataTrigger Value="Maximized"
                        Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Setter Property="CornerRadius" Value="0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 自定义标题栏 -->
            <Border Grid.Row="0" Background="{StaticResource BackgroundDark}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：App 图标 + 标题 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                        <Viewbox Width="14" Height="14" VerticalAlignment="Center">
                            <Path Data="M1,0.5 L8.5,5 L1,9.5 Z"
                                  Fill="{StaticResource AccentBlue}"/>
                        </Viewbox>
                        <TextBlock Text="LocalPlayer" VerticalAlignment="Center"
                                   Margin="8,0,0,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <!-- 中间拖拽区域（WindowChrome caption 自动处理拖拽和双击最大化） -->
                    <Grid Grid.Column="1" Background="Transparent"/>

                    <!-- 右侧：窗口控制按钮 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <!-- 最小化 -->
                        <Button Style="{StaticResource IconButton}"
                                Click="MinimizeButton_Click" ToolTip="最小化"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="10" Height="10">
                                <Path Data="{StaticResource MinimizeIconGeometry}" Stroke="White"
                                      StrokeThickness="1.2" StrokeEndLineCap="Round"/>
                            </Viewbox>
                        </Button>

                        <!-- 最大化 / 还原 -->
                        <Button Click="MaximizeButton_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="10" Height="10">
                                <Grid>
                                    <Path Data="{StaticResource MaximizeIconGeometry}" Stroke="White"
                                          StrokeThickness="1.2">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Style.Triggers>
                                                    <DataTrigger Value="Maximized"
                                                        Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <Path Data="{StaticResource RestoreIconGeometry}"
                                          Stroke="White" StrokeThickness="1.2">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Value="Maximized"
                                                        Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                </Grid>
                            </Viewbox>
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconButton}">
                                    <Setter Property="ToolTip" Value="最大化"/>
                                    <Style.Triggers>
                                        <DataTrigger Value="Maximized"
                                            Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}">
                                            <Setter Property="ToolTip" Value="还原"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- 关闭 -->
                        <Button Style="{StaticResource CloseIconButton}"
                                Click="CloseButton_Click" ToolTip="关闭"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Viewbox Width="10" Height="10">
                                <Path Data="{StaticResource CloseIconGeometry}" Stroke="White"
                                      StrokeThickness="1.3" StrokeEndLineCap="Round"/>
                            </Viewbox>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 页面内容 -->
            <primitives:TransitioningContentControl Grid.Row="1"
                Content="{Binding CurrentPage}"/>
        </Grid>
    </Border>
</Window>
