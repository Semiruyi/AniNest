<Application x:Class="LocalPlayer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             >
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/View/Styles/IconGeometries.xaml"/>
                <ResourceDictionary Source="/View/Styles/SharedStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 核心颜色 -->
            <SolidColorBrush x:Key="BackgroundDark" Color="#FF1E1E1E"/>
            <SolidColorBrush x:Key="SurfaceDark" Color="#FF141414"/>
            <SolidColorBrush x:Key="SurfaceLight" Color="#FF1E1E1E"/>
            <Color x:Key="AccentBlueColor">#FF007AFF</Color>
            <SolidColorBrush x:Key="AccentBlue" Color="{StaticResource AccentBlueColor}"/>
            <SolidColorBrush x:Key="AccentBlueHover" Color="#FF3399FF"/>
            <SolidColorBrush x:Key="AccentBlueActive" Color="#FF66B5FF"/>
            <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#AAFFFFFF"/>
            <SolidColorBrush x:Key="HoverBackground" Color="#22FFFFFF"/>
            <SolidColorBrush x:Key="PressedBackground" Color="#33FFFFFF"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>
