<Window x:Class="LocalPlayer.View.Settings.KeyBindingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="键盘快捷键设置" Height="520" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="PlainButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#E61C1C1E" CornerRadius="14">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="56"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Background="#22FFFFFF" CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="键盘快捷键" Foreground="White" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="20,0,0,0"
                               FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                    <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets"
                            Style="{StaticResource PlainButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Width="32" Height="32"
                            Margin="0,0,8,0"
                            Click="CloseBtn_Click" Foreground="#AAFFFFFF" FontSize="12"/>
                </Grid>
            </Border>

            <!-- 快捷键列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,12,16,0">
                <ItemsControl x:Name="KeyBindingsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#18FFFFFF" CornerRadius="8" Padding="12,10" Margin="0,0,0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="140"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}" Foreground="White" FontSize="13"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                                    <Button Grid.Column="1"
                                            Style="{StaticResource PlainButton}"
                                            HorizontalAlignment="Stretch"
                                            Click="KeyBindingBtn_Click"
                                            Tag="{Binding}"
                                            Padding="10,6">
                                        <TextBlock Text="{Binding CurrentKeyDisplay, FallbackValue='...'}"
                                                   Foreground="#66CCFF" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 底部按钮 -->
            <Border Grid.Row="2" Background="#22FFFFFF" CornerRadius="0,0,14,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Button Content="恢复默认" Style="{StaticResource PlainButton}"
                            Foreground="#AAFFFFFF" FontSize="12"
                            Padding="14,6"
                            Click="ResetDefaultBtn_Click"
                            FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                    <Button Content="完成" Style="{StaticResource PlainButton}"
                            Foreground="{StaticResource AccentBlue}" FontSize="12"
                            FontWeight="SemiBold"
                            Padding="20,6" Margin="8,0,0,0"
                            Click="DoneBtn_Click"
                            FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
