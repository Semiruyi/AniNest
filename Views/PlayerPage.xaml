<UserControl x:Class="LocalPlayer.Views.PlayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             Background="{StaticResource BackgroundDark}"
             Focusable="True"
             PreviewKeyDown="PlayerPage_PreviewKeyDown"
             KeyDown="PlayerPage_KeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频区 -->
        <Grid x:Name="VideoContainer" Grid.Row="0" Grid.Column="0" Background="Black"
              GotFocus="VideoContainer_GotFocus" LostFocus="VideoContainer_LostFocus"
              MouseLeftButtonDown="VideoContainer_MouseLeftButtonDown"
              MouseRightButtonDown="VideoContainer_MouseRightButtonDown">
            <vlc:VideoView x:Name="VideoView" GotFocus="VideoView_GotFocus" LostFocus="VideoView_LostFocus">
                <!-- 透明覆盖层：LibVLCSharp.WPF 会把 Content 渲染到视频上方的透明窗口中，
                     用于绕过 Airspace 限制并拦截鼠标事件 -->
                <Grid Background="Transparent"
                      MouseLeftButtonDown="OverlayGrid_MouseLeftButtonDown"
                      MouseRightButtonDown="OverlayGrid_MouseRightButtonDown"/>
            </vlc:VideoView>
        </Grid>

        <!-- 播放列表 -->
        <Border x:Name="PlaylistBorder" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Width="260" Background="{StaticResource SurfaceDark}"
                BorderBrush="#333333" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Background="#252525">
                    <TextBlock Text="播放列表" Foreground="White" Margin="15,12" FontSize="14" FontWeight="SemiBold"/>
                </Grid>
                <ListBox x:Name="PlaylistBox" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Foreground="White" Margin="5" SelectionChanged="PlaylistBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="2">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- 控制栏 -->
        <Grid x:Name="ControlBar" Grid.Row="1" Grid.Column="0" Height="65" Background="{StaticResource SurfaceDark}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,0">
                <Button x:Name="PlayPauseBtn" Content="▶" Width="42" Height="42"
                        Background="{StaticResource AccentBlue}" Foreground="White" BorderThickness="0"
                        FontSize="16" Click="PlayPauseBtn_Click" Cursor="Hand"/>
                <Button x:Name="StopBtn" Content="■" Width="42" Height="42" Margin="8,0,0,0"
                        Background="#333333" Foreground="White" BorderThickness="0"
                        FontSize="14" Click="StopBtn_Click" Cursor="Hand"/>
            </StackPanel>

            <Grid Grid.Column="1" Margin="10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Slider x:Name="ProgressSlider" VerticalAlignment="Center"
                        Background="Transparent" Foreground="{StaticResource AccentBlue}"
                        PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                        PreviewMouseUp="ProgressSlider_PreviewMouseUp"
                        ValueChanged="ProgressSlider_ValueChanged"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock x:Name="CurrentTimeText" Text="00:00" Foreground="#AAAAAA" FontSize="11"/>
                    <TextBlock Text=" / " Foreground="#666666" FontSize="11"/>
                    <TextBlock x:Name="TotalTimeText" Text="00:00" Foreground="#AAAAAA" FontSize="11"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="15,0">
                <Button x:Name="PlaylistToggleBtn" Content="☰" Width="42" Height="42"
                        Background="#333333" Foreground="White" BorderThickness="0"
                        FontSize="16" Click="PlaylistToggleBtn_Click" Cursor="Hand"/>
                <Button x:Name="BackBtn" Content="←" Width="42" Height="42" Margin="8,0,0,0"
                        Background="#333333" Foreground="White" BorderThickness="0"
                        FontSize="16" Click="BackBtn_Click" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
