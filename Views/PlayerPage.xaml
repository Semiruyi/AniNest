<UserControl x:Class="LocalPlayer.Views.PlayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             Background="{StaticResource BackgroundDark}"
             Focusable="True"
             PreviewKeyDown="PlayerPage_PreviewKeyDown"
             KeyDown="PlayerPage_KeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频区 -->
        <Grid x:Name="VideoContainer" Grid.Row="0" Grid.Column="0" Background="Black"
              GotFocus="VideoContainer_GotFocus" LostFocus="VideoContainer_LostFocus"
              MouseLeftButtonDown="VideoContainer_MouseLeftButtonDown"
              MouseRightButtonDown="VideoContainer_MouseRightButtonDown">
            <vlc:VideoView x:Name="VideoView" GotFocus="VideoView_GotFocus" LostFocus="VideoView_LostFocus">
                <Grid x:Name="OverlayGrid"
                      Background="#01000000"
                      MouseLeftButtonDown="OverlayGrid_MouseLeftButtonDown"
                      MouseRightButtonDown="OverlayGrid_MouseRightButtonDown"/>
            </vlc:VideoView>
        </Grid>

        <!-- 选集 -->
        <Border x:Name="PlaylistBorder" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Width="260" Background="{StaticResource SurfaceDark}"
                BorderBrush="#333333" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Background="#252525" Height="44">
                    <TextBlock Text="选集" Foreground="White" Margin="16,0" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="EpisodeCountText" Foreground="#66FFFFFF" FontSize="11"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"/>
                </Grid>

                <!-- Episode Grid -->
                <ListBox x:Name="PlaylistBox" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Margin="8,10,8,8" SelectionChanged="PlaylistBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="4"/>
                            <Setter Property="Width" Value="48"/>
                            <Setter Property="Height" Value="48"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid x:Name="RootGrid" RenderTransformOrigin="0.5,0.5">
                                            <Grid.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Grid.RenderTransform>
                                            <Border x:Name="BgBorder"
                                                    Background="#252525"
                                                    BorderBrush="#333333"
                                                    BorderThickness="1"
                                                    CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BgBorder" Property="Background" Value="#333333"/>
                                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#444444"/>
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                To="1.08" Duration="0:0:0.12" EasingFunction="{StaticResource EaseOut}"/>
                                                            <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                To="1.08" Duration="0:0:0.12" EasingFunction="{StaticResource EaseOut}"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                To="1" Duration="0:0:0.18" EasingFunction="{StaticResource EaseOut}"/>
                                                            <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                To="1" Duration="0:0:0.18" EasingFunction="{StaticResource EaseOut}"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource AccentBlue}"/>
                                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{StaticResource AccentBlue}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Number, StringFormat={}{0:D2}}"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center">
                                <TextBlock.ToolTip>
                                    <ToolTip Background="#1E1E1E" BorderBrush="#444444" Foreground="White" Padding="8,4" BorderThickness="1">
                                        <TextBlock Text="{Binding Title}" FontSize="12" MaxWidth="220" TextTrimming="CharacterEllipsis"/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 控制栏 -->
        <Grid x:Name="ControlBar" Grid.Row="1" Grid.Column="0" Height="63">
            <Grid.Background>
                <SolidColorBrush Color="#CC0F0F0F"/>
            </Grid.Background>

            <Grid Margin="10,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：播放控制 + 时间 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="PreviousBtn" Style="{StaticResource IconButton}" Click="PreviousBtn_Click" ToolTip="上一集 (P)">
                        <Image Source="/Resources/Icons/previous.png" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="PlayPauseBtn" Style="{StaticResource PlayButton}" Click="PlayPauseBtn_Click" Margin="2,0" ToolTip="播放/暂停 (Space)">
                        <Image x:Name="PlayPauseIcon" Source="/Resources/Icons/play.png" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="NextBtn" Style="{StaticResource IconButton}" Click="NextBtn_Click" ToolTip="下一集 (N)">
                        <Image Source="/Resources/Icons/next.png" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="StopBtn" Style="{StaticResource IconButton}" Click="StopBtn_Click" Margin="2,0,0,0" ToolTip="停止">
                        <Image Source="/Resources/Icons/stop.png" Width="14" Height="14"/>
                    </Button>
                    <TextBlock x:Name="CurrentTimeText" Text="00:00"
                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                    <TextBlock Text=" / " Foreground="#66FFFFFF" FontSize="11"
                               VerticalAlignment="Center" Margin="2,0"/>
                    <TextBlock x:Name="TotalTimeText" Text="00:00"
                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                               VerticalAlignment="Center" FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                </StackPanel>

                <!-- 中间：进度条 -->
                <Slider x:Name="ProgressSlider" Grid.Column="1"
                        Style="{StaticResource ModernSlider}"
                        PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                        PreviewMouseUp="ProgressSlider_PreviewMouseUp"
                        ValueChanged="ProgressSlider_ValueChanged"
                        LostMouseCapture="ProgressSlider_LostMouseCapture"
                        VerticalAlignment="Center"
                        Margin="10,0"/>

                <!-- 右侧：菜单 + 全屏 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="PlaylistToggleBtn" Style="{StaticResource IconButton}" Click="PlaylistToggleBtn_Click" ToolTip="选集">
                        <Image Source="/Resources/Icons/playlist.png" Width="16" Height="16"/>
                    </Button>
                    <Button x:Name="FullscreenBtn" Style="{StaticResource IconButton}" Click="FullscreenBtn_Click" Margin="2,0,0,0" ToolTip="全屏 (F)">
                        <Image x:Name="FullscreenIcon" Source="/Resources/Icons/fullScreen.png" Width="16" Height="16"/>
                    </Button>
                    <Button x:Name="BackBtn" Style="{StaticResource IconButton}" Click="BackBtn_Click" Margin="2,0,0,0" ToolTip="返回 (Esc)">
                        <Image Source="/Resources/Icons/back.png" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
