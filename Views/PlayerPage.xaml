<UserControl x:Class="LocalPlayer.Views.PlayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
             Background="{StaticResource BackgroundDark}"
             Focusable="True"
             PreviewKeyDown="PlayerPage_PreviewKeyDown"
             KeyDown="PlayerPage_KeyDown">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频区 -->
        <Grid x:Name="VideoContainer" Grid.Row="0" Grid.Column="0" Background="Black"
              GotFocus="VideoContainer_GotFocus" LostFocus="VideoContainer_LostFocus"
              MouseLeftButtonDown="VideoContainer_MouseLeftButtonDown"
              MouseRightButtonDown="VideoContainer_MouseRightButtonDown">
            <vlc:VideoView x:Name="VideoView" GotFocus="VideoView_GotFocus" LostFocus="VideoView_LostFocus"/>
        </Grid>

        <!-- 播放列表 -->
        <Border x:Name="PlaylistBorder" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Width="260" Background="{StaticResource SurfaceDark}"
                BorderBrush="#333333" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Background="#252525">
                    <TextBlock Text="播放列表" Foreground="White" Margin="15,12" FontSize="14" FontWeight="SemiBold"/>
                </Grid>
                <ListBox x:Name="PlaylistBox" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Foreground="White" Margin="5" SelectionChanged="PlaylistBox_SelectionChanged">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Margin="2">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#333333"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>
            </Grid>
        </Border>

        <!-- 控制栏 -->
        <Grid x:Name="ControlBar" Grid.Row="1" Grid.Column="0" Height="68">
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#000A0A0A" Offset="0"/>
                    <GradientStop Color="#DD0A0A0A" Offset="0.5"/>
                    <GradientStop Color="#EE0A0A0A" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid Margin="16,6,16,0" VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 进度条：全宽居中 -->
                <Slider x:Name="ProgressSlider" Grid.Row="0"
                        Style="{StaticResource ModernSlider}"
                        PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                        PreviewMouseUp="ProgressSlider_PreviewMouseUp"
                        ValueChanged="ProgressSlider_ValueChanged"
                        Margin="0,0,0,2"/>

                <!-- 底部按钮行 -->
                <Grid Grid.Row="1" Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左侧：播放控制 + 时间 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button x:Name="PreviousBtn" Style="{StaticResource IconButton}" Click="PreviousBtn_Click" ToolTip="上一集 (P)">
                            <Image Source="/Resources/Icons/previous.png" Width="16" Height="16"/>
                        </Button>
                        <Button x:Name="PlayPauseBtn" Style="{StaticResource PlayButton}" Click="PlayPauseBtn_Click" Margin="4,0" ToolTip="播放/暂停 (Space)">
                            <Image x:Name="PlayPauseIcon" Source="/Resources/Icons/play.png" Width="22" Height="22"/>
                        </Button>
                        <Button x:Name="NextBtn" Style="{StaticResource IconButton}" Click="NextBtn_Click" ToolTip="下一集 (N)">
                            <Image Source="/Resources/Icons/next.png" Width="16" Height="16"/>
                        </Button>
                        <Button x:Name="StopBtn" Style="{StaticResource IconButton}" Click="StopBtn_Click" Margin="4,0,0,0" ToolTip="停止">
                            <Image Source="/Resources/Icons/stop.png" Width="16" Height="16"/>
                        </Button>
                        <TextBlock x:Name="CurrentTimeText" Text="00:00"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" Margin="12,0,0,0" FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                        <TextBlock Text=" / " Foreground="#66FFFFFF" FontSize="11"
                                   VerticalAlignment="Center" Margin="2,0"/>
                        <TextBlock x:Name="TotalTimeText" Text="00:00"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                    </StackPanel>

                    <!-- 中间留空，进度条已占满全宽 -->

                    <!-- 右侧：菜单 + 全屏 -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="PlaylistToggleBtn" Style="{StaticResource IconButton}" Click="PlaylistToggleBtn_Click" ToolTip="播放列表">
                            <Image Source="/Resources/Icons/playlist.png" Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="FullscreenBtn" Style="{StaticResource IconButton}" Click="FullscreenBtn_Click" Margin="4,0,0,0" ToolTip="全屏 (F)">
                            <Image x:Name="FullscreenIcon" Source="/Resources/Icons/fullScreen.png" Width="18" Height="18"/>
                        </Button>
                        <Button x:Name="BackBtn" Style="{StaticResource IconButton}" Click="BackBtn_Click" Margin="4,0,0,0" ToolTip="返回 (Esc)">
                            <Image Source="/Resources/Icons/back.png" Width="18" Height="18"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
