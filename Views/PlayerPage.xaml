<UserControl x:Class="LocalPlayer.Views.PlayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:LocalPlayer.Views"
             Background="{StaticResource BackgroundDark}"
             Focusable="True"
             PreviewKeyDown="PlayerPage_PreviewKeyDown"
             KeyDown="PlayerPage_KeyDown">
    <Grid x:Name="PageRoot" Opacity="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频区 -->
        <Grid x:Name="VideoContainer" Grid.Row="0" Grid.Column="0" Background="Black"
              MouseLeftButtonDown="VideoContainer_MouseLeftButtonDown"
              MouseDown="VideoContainer_MouseDown">
            <Image x:Name="VideoImage" Stretch="Uniform"/>
            <!-- 暂停大图标（右下角） -->
            <Image x:Name="PauseBigIcon"
                   Source="/Resources/Icons/pause-big.png"
                   Width="80" Height="80"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,32,24"
                   Opacity="0"
                   RenderTransformOrigin="0.5,0.5">
                <Image.RenderTransform>
                    <ScaleTransform x:Name="PauseBigIconScale" ScaleX="0" ScaleY="0"/>
                </Image.RenderTransform>
            </Image>
        </Grid>

        <!-- 选集面板 -->
        <views:PlaylistPanelView x:Name="PlaylistPanel"
                                 Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"/>

        <!-- 控制栏 -->
        <views:ControlBarView x:Name="ControlBar"
                              Grid.Row="1" Grid.Column="0"/>
    </Grid>
</UserControl>
