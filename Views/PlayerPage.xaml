<UserControl x:Class="LocalPlayer.Views.PlayerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:LocalPlayer.Views"
             Background="{StaticResource BackgroundDark}"
             Focusable="True"
             PreviewKeyDown="PlayerPage_PreviewKeyDown"
             KeyDown="PlayerPage_KeyDown">
    <Grid x:Name="PageRoot" Opacity="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 视频区 -->
        <Grid x:Name="VideoContainer" Grid.Row="0" Grid.Column="0" Background="Black"
              MouseLeftButtonDown="VideoContainer_MouseLeftButtonDown"
              MouseDown="VideoContainer_MouseDown">
            <Image x:Name="VideoImage" Stretch="Uniform"/>
        </Grid>

        <!-- 选集 -->
        <Border x:Name="PlaylistBorder" Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                Width="276" Background="#1A1A1C"
                BorderBrush="#222224" BorderThickness="1,0,0,0"
                MouseEnter="PlaylistBorder_MouseEnter" MouseLeave="PlaylistBorder_MouseLeave">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="20,18,20,10">
                    <TextBlock Text="选集" Foreground="White" FontSize="15"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="EpisodeCountText" Foreground="#8E8E93" FontSize="12"
                               VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Episode Grid -->
                <ListBox x:Name="PlaylistBox" Grid.Row="1" Background="Transparent" BorderThickness="0"
                         Margin="14,4,14,14" SelectionChanged="PlaylistBox_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ScrollBar">
                                        <Grid>
                                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                <Track.Thumb>
                                                    <Thumb>
                                                        <Thumb.Template>
                                                            <ControlTemplate TargetType="Thumb">
                                                                <Border Background="#28FFFFFF"
                                                                        CornerRadius="2"
                                                                        Width="4"/>
                                                            </ControlTemplate>
                                                        </Thumb.Template>
                                                    </Thumb>
                                                </Track.Thumb>
                                            </Track>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.Resources>
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <views:AnimatedWrapPanel Orientation="Horizontal"
                                                     AnimationDuration="0:0:0.2"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="3"/>
                            <Setter Property="Width" Value="54"/>
                            <Setter Property="Height" Value="54"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource EpisodeButton}" Click="EpisodeButton_Click">
                                <TextBlock Text="{Binding Number, StringFormat={}{0:D2}}"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                           FontSize="15"
                                           FontWeight="Medium"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.ToolTip>
                                        <ToolTip Background="#1C1C1E" BorderBrush="#38383A"
                                                 Foreground="White" Padding="10,5" BorderThickness="1"
                                                 FontSize="12">
                                            <TextBlock Text="{Binding Title}" MaxWidth="220"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </ToolTip>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 控制栏 -->
        <Grid x:Name="ControlBar" Grid.Row="1" Grid.Column="0" Height="63"
              Focusable="True"
              PreviewKeyDown="ControlBar_PreviewKeyDown"
              KeyDown="ControlBar_KeyDown"
              MouseEnter="ControlBar_MouseEnter" MouseLeave="ControlBar_MouseLeave">
            <Grid.Background>
                <SolidColorBrush Color="#CC0F0F0F"/>
            </Grid.Background>

            <Grid Margin="10,0,10,0" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧：播放控制 + 时间 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Button x:Name="PreviousBtn" Style="{StaticResource IconButton}" Click="PreviousBtn_Click" ToolTip="上一集 (P)" Focusable="False">
                        <Image Source="/Resources/Icons/previous.png" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="PlayPauseBtn" Style="{StaticResource PlayButton}" Click="PlayPauseBtn_Click" Margin="2,0" ToolTip="播放/暂停 (Space)" Focusable="False">
                        <Image x:Name="PlayPauseIcon" Source="/Resources/Icons/play.png" Width="20" Height="20"/>
                    </Button>
                    <Button x:Name="NextBtn" Style="{StaticResource IconButton}" Click="NextBtn_Click" ToolTip="下一集 (N)" Focusable="False">
                        <Image Source="/Resources/Icons/next.png" Width="14" Height="14"/>
                    </Button>
                    <Button x:Name="StopBtn" Style="{StaticResource IconButton}" Click="StopBtn_Click" Margin="2,0,0,0" ToolTip="停止" Focusable="False">
                        <Image Source="/Resources/Icons/stop.png" Width="14" Height="14"/>
                    </Button>
                    <TextBlock x:Name="CurrentTimeText" Text="00:00"
                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                               VerticalAlignment="Center" Margin="10,0,0,0" FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                    <TextBlock Text=" / " Foreground="#66FFFFFF" FontSize="11"
                               VerticalAlignment="Center" Margin="2,0"/>
                    <TextBlock x:Name="TotalTimeText" Text="00:00"
                               Foreground="{StaticResource TextSecondary}" FontSize="11"
                               VerticalAlignment="Center" FontFamily="Segoe UI, Microsoft YaHei, sans-serif"/>
                </StackPanel>

                <!-- 中间：进度条 -->
                <Slider x:Name="ProgressSlider" Grid.Column="1"
                        Style="{StaticResource ModernSlider}"
                        PreviewMouseDown="ProgressSlider_PreviewMouseDown"
                        PreviewMouseUp="ProgressSlider_PreviewMouseUp"
                        ValueChanged="ProgressSlider_ValueChanged"
                        LostMouseCapture="ProgressSlider_LostMouseCapture"
                        VerticalAlignment="Center"
                        Margin="10,0"/>

                <!-- 右侧：菜单 + 全屏 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="PlaylistToggleBtn" Style="{StaticResource IconButton}" Click="PlaylistToggleBtn_Click" ToolTip="选集" Focusable="False">
                        <Image Source="/Resources/Icons/playlist.png" Width="16" Height="16"/>
                    </Button>
                    <Button x:Name="FullscreenBtn" Style="{StaticResource IconButton}" Click="FullscreenBtn_Click" Margin="2,0,0,0" ToolTip="全屏 (F)" Focusable="False">
                        <Image x:Name="FullscreenIcon" Source="/Resources/Icons/fullScreen.png" Width="16" Height="16"/>
                    </Button>

                </StackPanel>
            </Grid>
        </Grid>

    </Grid>
</UserControl>
