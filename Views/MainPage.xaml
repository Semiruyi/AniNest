<UserControl x:Class="LocalPlayer.Views.MainPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundDark}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="FolderList" Margin="20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Height="120" Margin="10" Background="{StaticResource SurfaceDark}"
                                CornerRadius="8" MouseLeftButtonUp="FolderCard_Click" Tag="{Binding Path}"
                                Cursor="Hand">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding Name}" Foreground="White" VerticalAlignment="Center"
                                           HorizontalAlignment="Center" TextWrapping="Wrap" Margin="10"
                                           FontSize="14" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="1" Text="{Binding VideoCount, StringFormat='{}{0} 个视频'}"
                                           Foreground="#AAA" HorizontalAlignment="Right" Margin="10,5"
                                           FontSize="12"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="1" Height="80" Background="{StaticResource SurfaceDark}">
            <Button x:Name="AddFolderBtn" Content="➕ 添加文件夹" Width="160" Height="40"
                    Background="{StaticResource AccentBlue}" Foreground="White" BorderThickness="0"
                    HorizontalAlignment="Center" Click="AddFolderBtn_Click" FontSize="13"/>
        </Border>
    </Grid>
</UserControl>
