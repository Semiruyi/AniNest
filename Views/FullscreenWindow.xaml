<Window x:Class="LocalPlayer.Views.FullscreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        Background="Black"
        Focusable="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyDown="Window_KeyDown">
    <Grid x:Name="RootGrid" Background="Black">
        <Image x:Name="VideoImage" Stretch="Uniform"/>
        <!-- 暂停大图标（右下角） -->
        <Image x:Name="PauseBigIcon"
               Source="/Resources/Icons/pause-big.png"
               Width="80" Height="80"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Margin="0,0,32,24"
               Opacity="0"
               RenderTransformOrigin="0.5,0.5">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="PauseBigIconScale" ScaleX="0" ScaleY="0"/>
                    <TranslateTransform x:Name="PauseBigIconFSTranslate" X="0" Y="0"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
    </Grid>
</Window>
